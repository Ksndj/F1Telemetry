<Window x:Class="F1Telemetry.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:shell="clr-namespace:F1Telemetry.App.Views.Shell"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitleText}"
        Width="1380"
        Height="860"
        MinWidth="860"
        MinHeight="580"
        WindowState="Normal"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing"
        Closed="Window_Closed">
    <Grid x:Name="WindowRoot"
          Background="{StaticResource BgDeepBrush}"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="WindowRootScaleTransform"
                            ScaleX="1"
                            ScaleY="1" />
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumnDefinition"
                              Width="{Binding DataContext.SidebarColumnWidth, ElementName=WindowRoot}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <shell:Sidebar x:Name="Sidebar"
                       Grid.RowSpan="2" />

        <shell:TopStatusBar x:Name="TopStatusBar"
                            Grid.Column="1" />

        <ScrollViewer x:Name="ContentHostScrollViewer"
                      Grid.Row="1"
                      Grid.Column="1"
                      Margin="16,0,20,20"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="ContentHostScrollViewer_PreviewMouseWheel">
            <ContentControl x:Name="ContentHost"
                            Content="{Binding SelectedShellNavigationItem}"
                            ContentTemplateSelector="{StaticResource ShellNavigationTemplateSelector}" />
        </ScrollViewer>

        <shell:ToastOverlay x:Name="WindowStateToastOverlay"
                            Grid.ColumnSpan="2"
                            Grid.RowSpan="2"
                            Panel.ZIndex="20" />
    </Grid>
</Window>
