<Window x:Class="F1Telemetry.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:attached="clr-namespace:F1Telemetry.App.AttachedProperties"
        xmlns:controls="clr-namespace:F1Telemetry.App.Views.Controls"
        xmlns:views="clr-namespace:F1Telemetry.App.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitleText}"
        Width="1380"
        Height="860"
        MinWidth="1160"
        MinHeight="720"
        MaxWidth="1920"
        MaxHeight="1080"
        WindowState="Normal"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="OverviewContentTemplate">
            <views:OverviewView />
        </DataTemplate>

        <DataTemplate x:Key="ChartsContentTemplate">
            <views:ChartsView />
        </DataTemplate>

        <DataTemplate x:Key="LapHistoryContentTemplate">
            <views:LapHistoryView />
        </DataTemplate>

        <DataTemplate x:Key="OpponentsContentTemplate">
            <views:OpponentsView />
        </DataTemplate>

        <DataTemplate x:Key="LogsContentTemplate">
            <views:LogsView />
        </DataTemplate>

        <DataTemplate x:Key="AiTtsContentTemplate">
            <views:AiTtsView />
        </DataTemplate>

        <DataTemplate x:Key="SettingsContentTemplate">
            <views:SettingsView />
        </DataTemplate>

        <DataTemplate x:Key="PlaceholderContentTemplate">
            <Border Padding="24"
                    CornerRadius="20"
                    Background="#0F1B2E">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding SelectedShellNavigationTitle}"
                               TextAlignment="Center" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="16"
                               Foreground="#9AB0C9"
                               Text="将在后续里程碑拆分"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LegacyDashboardContentTemplate">
            <views:LegacyDashboardView />
        </DataTemplate>

        <Style x:Key="ShellNavigationItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#D7E4F3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Padding="14,11"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#132743" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#1D3558" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1557A9" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2387F8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="WindowRoot"
          Background="#08111F"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="WindowRootScaleTransform"
                            ScaleX="1"
                            ScaleY="1" />
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="Sidebar"
                Grid.RowSpan="2"
                Margin="16,16,0,16"
                Padding="14"
                CornerRadius="18"
                Background="#0F1B2E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Grid Width="120"
                          Height="96"
                          HorizontalAlignment="Center">
                        <Ellipse Width="56"
                                 Height="56"
                                 Margin="8,8,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Fill="#102A45"
                                 Stroke="#20A8FF"
                                 StrokeThickness="2" />
                        <Path Data="M33,26 C18,31 16,52 28,64 L45,75"
                              Stroke="#20A8FF"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Path Data="M38,24 L70,24 L82,36 L70,45 L43,45 C38,39 36,31 38,24 Z"
                              Fill="#0B1628"
                              Stroke="#D7E4F3"
                              StrokeThickness="2" />
                        <Path Data="M48,45 L68,64 L93,64"
                              Stroke="#20A8FF"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Path Data="M74,25 L98,46 L112,26"
                              Stroke="#20A8FF"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Path Data="M86,70 L104,52 M99,52 L107,44"
                              Stroke="#D7E4F3"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Grid>

                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding ApplicationVersionText, StringFormat=遥测软件 {0}}" />
                </StackPanel>

                <ListBox x:Name="ShellNavigationList"
                         Grid.Row="1"
                         Margin="0,22,0,0"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource ShellNavigationItemStyle}"
                         ItemsSource="{Binding ShellNavigationItems}"
                         SelectedItem="{Binding SelectedShellNavigationItem, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=Foreground}"
                                       Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        Padding="12,14"
                        CornerRadius="14"
                        Background="#0B1728">
                    <StackPanel>
                        <TextBlock Foreground="#2DE274"
                                   Text="{Binding ConnectionStateText}" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#9AB0C9"
                                   Text="使用中: 20777 UDP" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="TopStatusBar"
                Grid.Column="1"
                Margin="16,16,20,16"
                Padding="22"
                CornerRadius="22"
                Background="#0F1B2E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock x:Name="ShellTitleText"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding AppTitleText}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9AB0C9"
                               Text="{Binding Subtitle}" />

                    <WrapPanel Margin="0,18,0,0">
                        <Border Margin="0,0,12,0" Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="连接状态" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding ConnectionStateText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="赛道" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding TrackText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="圈数" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding LapText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="天气" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding WeatherText}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="UDP PPS" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding PacketsPerSecond}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Foreground="#7FA5D8" Text="监听端口" />
                    <TextBox Width="120"
                             Margin="0,8,0,0"
                             Padding="10,6"
                             Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                        <Button Width="108"
                                Height="36"
                                Margin="0,0,10,0"
                                Command="{Binding StartListeningCommand}"
                                Content="开始监听" />
                        <Button Width="108"
                                Height="36"
                                Command="{Binding StopListeningCommand}"
                                Content="停止监听" />
                    </StackPanel>
                    <TextBlock Width="240"
                               Margin="0,14,0,0"
                               Foreground="#B5C7DC"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <ContentControl x:Name="ContentHost"
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="16,0,20,20"
                        ClipToBounds="True"
                        Content="{Binding}">
            <ContentControl.Style>
                <Style TargetType="{x:Type ContentControl}">
                    <Setter Property="ContentTemplate" Value="{StaticResource OverviewContentTemplate}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChartsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource ChartsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLapHistorySelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource LapHistoryContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsOpponentsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource OpponentsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLogsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource LogsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsAiTtsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource AiTtsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource SettingsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsPlaceholderNavigationSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource PlaceholderContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLegacyDashboardSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource LegacyDashboardContentTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <Border x:Name="WindowStateToast"
                Grid.ColumnSpan="2"
                Grid.RowSpan="2"
                Margin="0,24,24,0"
                Padding="14,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="20"
                Background="#E6EEF9"
                BorderBrush="#BDD0EA"
                BorderThickness="1"
                CornerRadius="14"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="WindowStateToastScaleTransform"
                                    ScaleX="0.96"
                                    ScaleY="0.96" />
                    <TranslateTransform x:Name="WindowStateToastTranslateTransform"
                                        Y="-6" />
                </TransformGroup>
            </Border.RenderTransform>
            <TextBlock x:Name="WindowStateToastText"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#132743"
                       Text="窗口状态已更新" />
        </Border>
    </Grid>
</Window>
