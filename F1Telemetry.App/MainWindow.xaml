<Window x:Class="F1Telemetry.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:attached="clr-namespace:F1Telemetry.App.AttachedProperties"
        xmlns:controls="clr-namespace:F1Telemetry.App.Views.Controls"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Width="1380"
        Height="860"
        MinWidth="1160"
        MinHeight="720"
        MaxWidth="1920"
        MaxHeight="1080"
        WindowState="Normal"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged">
    <Window.Resources>
        <Style x:Key="ShellNavigationItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#D7E4F3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Padding="14,11"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#132743" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#1D3558" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1557A9" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2387F8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="WindowRoot"
          Background="#08111F"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="WindowRootScaleTransform"
                            ScaleX="1"
                            ScaleY="1" />
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="Sidebar"
                Grid.RowSpan="2"
                Margin="16,16,0,16"
                Padding="14"
                CornerRadius="18"
                Background="#0F1B2E">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Grid Width="120"
                          Height="96"
                          HorizontalAlignment="Center">
                        <Ellipse Width="56"
                                 Height="56"
                                 Margin="8,8,0,0"
                                 HorizontalAlignment="Left"
                                 VerticalAlignment="Top"
                                 Fill="#102A45"
                                 Stroke="#20A8FF"
                                 StrokeThickness="2" />
                        <Path Data="M33,26 C18,31 16,52 28,64 L45,75"
                              Stroke="#20A8FF"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Path Data="M38,24 L70,24 L82,36 L70,45 L43,45 C38,39 36,31 38,24 Z"
                              Fill="#0B1628"
                              Stroke="#D7E4F3"
                              StrokeThickness="2" />
                        <Path Data="M48,45 L68,64 L93,64"
                              Stroke="#20A8FF"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Path Data="M74,25 L98,46 L112,26"
                              Stroke="#20A8FF"
                              StrokeThickness="3"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                        <Path Data="M86,70 L104,52 M99,52 L107,44"
                              Stroke="#D7E4F3"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round" />
                    </Grid>

                    <TextBlock Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="遥测软件 V1" />
                </StackPanel>

                <ListBox x:Name="ShellNavigationList"
                         Grid.Row="1"
                         Margin="0,22,0,0"
                         Background="Transparent"
                         BorderThickness="0"
                         ItemContainerStyle="{StaticResource ShellNavigationItemStyle}"
                         ItemsSource="{Binding ShellNavigationItems}"
                         SelectedItem="{Binding SelectedShellNavigationItem, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=Foreground}"
                                       Text="{Binding Name}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        Padding="12,14"
                        CornerRadius="14"
                        Background="#0B1728">
                    <StackPanel>
                        <TextBlock Foreground="#2DE274"
                                   Text="{Binding ConnectionStateText}" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#9AB0C9"
                                   Text="使用中: 20777 UDP" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="TopStatusBar"
                Grid.Column="1"
                Margin="16,16,20,16"
                Padding="22"
                CornerRadius="22"
                Background="#0F1B2E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding Title}" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9AB0C9"
                               Text="{Binding Subtitle}" />

                    <WrapPanel Margin="0,18,0,0">
                        <Border Margin="0,0,12,0" Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="连接状态" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding ConnectionStateText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="赛道" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding TrackText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="圈数" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding LapText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,0,12,0" Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="天气" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding WeatherText}" />
                            </StackPanel>
                        </Border>
                        <Border Padding="12,8" CornerRadius="14" Background="#132743">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="UDP PPS" />
                                <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding PacketsPerSecond}" />
                            </StackPanel>
                        </Border>
                    </WrapPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <TextBlock Foreground="#7FA5D8" Text="监听端口" />
                    <TextBox Width="120"
                             Margin="0,8,0,0"
                             Padding="10,6"
                             Text="{Binding PortText, UpdateSourceTrigger=PropertyChanged}" />
                    <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                        <Button Width="108"
                                Height="36"
                                Margin="0,0,10,0"
                                Command="{Binding StartListeningCommand}"
                                Content="开始监听" />
                        <Button Width="108"
                                Height="36"
                                Command="{Binding StopListeningCommand}"
                                Content="停止监听" />
                    </StackPanel>
                    <TextBlock Width="240"
                               Margin="0,14,0,0"
                               Foreground="#B5C7DC"
                               Text="{Binding StatusMessage}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid x:Name="ContentHost"
              Grid.Row="1"
              Grid.Column="1"
              Margin="16,0,20,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="220" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Padding="20" CornerRadius="20" Background="#0F1B2E">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="玩家实时卡片" />

                    <Border Margin="0,18,0,0" Padding="16" CornerRadius="16" Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="车手" />
                            <TextBlock Margin="0,6,0,0" FontSize="18" Foreground="White" Text="{Binding PlayerName}" />
                        </StackPanel>
                    </Border>

                    <UniformGrid Margin="0,16,0,0" Columns="2">
                        <Border Margin="0,0,8,8" Padding="14" CornerRadius="14" Background="#111F35">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="当前圈" />
                                <TextBlock Margin="0,6,0,0" Foreground="White" Text="{Binding PlayerCurrentLapText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,0,0,8" Padding="14" CornerRadius="14" Background="#111F35">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="位置" />
                                <TextBlock Margin="0,6,0,0" Foreground="White" Text="{Binding PlayerPositionText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,8,8,8" Padding="14" CornerRadius="14" Background="#111F35">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="上圈" />
                                <TextBlock Margin="0,6,0,0" Foreground="White" Text="{Binding PlayerLastLapText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,8,0,8" Padding="14" CornerRadius="14" Background="#111F35">
                            <StackPanel>
                                <TextBlock Foreground="#7FA5D8" Text="最佳圈" />
                                <TextBlock Margin="0,6,0,0" Foreground="White" Text="{Binding PlayerBestLapText}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Margin="0,8,0,0" Padding="16" CornerRadius="16" Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="前后车差距" />
                            <TextBlock Margin="0,6,0,0" Foreground="White" Text="{Binding PlayerGapText}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0" Padding="16" CornerRadius="16" Background="#132743">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Foreground="#7FA5D8" Text="燃油" />
                            <TextBlock Grid.Column="1" Foreground="White" Text="{Binding PlayerFuelText}" />

                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Foreground="#7FA5D8" Text="ERS" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Foreground="White" Text="{Binding PlayerErsText}" />

                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Foreground="#7FA5D8" Text="当前轮胎" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Foreground="White" Text="{Binding PlayerTyreText}" />

                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Foreground="#7FA5D8" Text="胎龄" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Foreground="White" Text="{Binding PlayerTyreAgeText}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="20" CornerRadius="20" Background="#0F1B2E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="320" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="实时图表" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#9AB0C9"
                                   Text="当前圈图表按 250ms 刷新，多圈趋势只在新圈生成后更新。" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <controls:TelemetryChartControl DataContext="{Binding SpeedChartPanel}" />
                        <controls:TelemetryChartControl Grid.Column="2"
                                                        DataContext="{Binding InputsChartPanel}" />
                        <controls:TelemetryChartControl Grid.Row="2"
                                                        DataContext="{Binding FuelTrendChartPanel}" />
                        <controls:TelemetryChartControl Grid.Row="2"
                                                        Grid.Column="2"
                                                        DataContext="{Binding TyreWearTrendChartPanel}" />
                    </Grid>

                    <StackPanel Grid.Row="3">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="单圈历史" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="#9AB0C9"
                                   Text="缓存保留整场圈摘要，界面默认显示最近 12 圈，最新圈在最上方。" />

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="12" CornerRadius="14" Background="#132743">
                                <StackPanel>
                                    <TextBlock Foreground="#7FA5D8" Text="Best" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="White"
                                               Text="{Binding BestLapSummaryText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Padding="12" CornerRadius="14" Background="#132743">
                                <StackPanel>
                                    <TextBlock Foreground="#7FA5D8" Text="Last" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="White"
                                               Text="{Binding LastLapSummaryText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <ListView Grid.Row="4"
                              Margin="0,18,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding RecentLapSummaries}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        CornerRadius="14"
                                        Background="#132743">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="74" />
                                            <ColumnDefinition Width="74" />
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Foreground="White" Text="{Binding LapText}" />
                                        <TextBlock Grid.Column="1" Foreground="#D7E4F3" Text="{Binding LapTimeText}" />
                                        <TextBlock Grid.Column="2" Foreground="#D7E4F3" Text="{Binding SectorsText}" />
                                        <TextBlock Grid.Column="3" Foreground="#D7E4F3" Text="{Binding AverageSpeedText}" />
                                        <TextBlock Grid.Column="4" Foreground="#D7E4F3" Text="{Binding FuelUsedLitresText}" />
                                        <TextBlock Grid.Column="5" Foreground="#D7E4F3" Text="{Binding ErsUsedText}" />
                                        <TextBlock Grid.Column="6" Foreground="#D7E4F3" Text="{Binding TyreWearDeltaText}" />
                                        <TextBlock Grid.Column="7" Foreground="#7FA5D8" Text="{Binding ValidityText}" />
                                        <TextBlock Grid.Column="8" Foreground="#D7E4F3" Text="{Binding TyreWindowText}" />
                                        <TextBlock Grid.Column="9" Foreground="#D7E4F3" Text="{Binding PitWindowText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="4" Padding="20" CornerRadius="20" Background="#0F1B2E">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="对手列表" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9AB0C9"
                               Text="车手、位置、轮胎、胎龄、pit 状态、与我差距" />

                    <ListView Margin="0,18,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding OpponentCars}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        CornerRadius="14"
                                        Background="#132743">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="86" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Foreground="White" Text="{Binding DisplayName}" />
                                        <TextBlock Grid.Column="1" Foreground="#D7E4F3" Text="{Binding PositionText}" />
                                        <TextBlock Grid.Column="2" Foreground="#D7E4F3" Text="{Binding TyreText}" />
                                        <TextBlock Grid.Column="3" Foreground="#D7E4F3" Text="{Binding TyreAgeText}" />
                                        <TextBlock Grid.Column="4" Foreground="#D7E4F3" Text="{Binding PitStatusText}" />
                                        <TextBlock Grid.Column="5" Foreground="#7FA5D8" Text="{Binding GapToPlayerText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>

            <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" CornerRadius="20" Background="#0F1B2E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="事件日志" />
                    <ListView Grid.Row="1"
                              Margin="0,16,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding EventLogs}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="#132743">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="#7FA5D8" Text="{Binding Timestamp}" />
                                        <TextBlock Grid.Column="1" Foreground="#D7E4F3" Text="{Binding Category}" />
                                        <TextBlock Grid.Column="2" Foreground="White" Text="{Binding Message}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="18" CornerRadius="20" Background="#0F1B2E">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="14"
                                CornerRadius="14"
                                Background="#132743">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="82" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Foreground="#7FA5D8" Text="AI 开关" />
                                <CheckBox Grid.Column="1"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding AiEnabled}" />

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Foreground="#7FA5D8"
                                           Text="Base URL" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,12,0,0"
                                         Padding="8,5"
                                         Text="{Binding AiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           Margin="0,12,0,0"
                                           Foreground="#7FA5D8"
                                           Text="Model" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,12,0,0"
                                         Padding="8,5"
                                         Text="{Binding AiModel, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3"
                                           Margin="0,12,0,0"
                                           Foreground="#7FA5D8"
                                           Text="API Key" />
                                <PasswordBox Grid.Row="3"
                                             Grid.Column="1"
                                             Margin="0,12,8,0"
                                             Padding="8,5"
                                             attached:PasswordBoxBinding.BoundPassword="{Binding AiApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="3"
                                           Grid.Column="2"
                                           Margin="0,12,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#9AB0C9"
                                           Text="{Binding AiApiKeyStatusText}" />

                                <TextBlock Grid.Row="4"
                                           Margin="0,12,0,0"
                                           Foreground="#7FA5D8"
                                           Text="TTS 开关" />
                                <CheckBox Grid.Row="4"
                                          Grid.Column="1"
                                          Margin="0,12,0,0"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding TtsEnabled}" />

                                <TextBlock Grid.Row="5"
                                           Margin="0,12,0,0"
                                           Foreground="#7FA5D8"
                                           Text="Voice" />
                                <TextBox Grid.Row="5"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,12,0,0"
                                         Padding="8,5"
                                         Text="{Binding TtsVoiceName, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="6"
                                           Margin="0,12,0,0"
                                           Foreground="#7FA5D8"
                                           Text="Volume" />
                                <Slider Grid.Row="6"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,12,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding TtsVolume}" />

                                <TextBlock Grid.Row="7"
                                           Margin="0,12,0,0"
                                           Foreground="#7FA5D8"
                                           Text="Rate" />
                                <Slider Grid.Row="7"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,12,0,0"
                                        Minimum="-10"
                                        Maximum="10"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding TtsRate}" />

                                <TextBlock Grid.Row="8"
                                           Margin="0,12,0,0"
                                           Foreground="#7FA5D8"
                                           Text="当前版本" />
                                <TextBlock Grid.Row="8"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Margin="0,12,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="#D7E4F3"
                                           Text="{Binding ApplicationVersionText}" />

                                <Button Grid.Row="9"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Width="132"
                                        Height="34"
                                        Margin="0,12,0,0"
                                        HorizontalAlignment="Left"
                                        Command="{Binding DownloadLatestVersionCommand}"
                                        Content="下载最新版本" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       Text="AI / TTS 日志" />
                            <ListView Grid.Row="1"
                                      Margin="0,16,0,0"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding AiTtsLogs}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                CornerRadius="12"
                                                Background="#132743">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="54" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="#7FA5D8" Text="{Binding Timestamp}" />
                                                <TextBlock Grid.Column="1" Foreground="#D7E4F3" Text="{Binding Category}" />
                                                <TextBlock Grid.Column="2" Foreground="White" Text="{Binding Message}" TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
        </Grid>

        <Border x:Name="WindowStateToast"
                Grid.ColumnSpan="2"
                Grid.RowSpan="2"
                Margin="0,24,24,0"
                Padding="14,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="20"
                Background="#E6EEF9"
                BorderBrush="#BDD0EA"
                BorderThickness="1"
                CornerRadius="14"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="WindowStateToastScaleTransform"
                                    ScaleX="0.96"
                                    ScaleY="0.96" />
                    <TranslateTransform x:Name="WindowStateToastTranslateTransform"
                                        Y="-6" />
                </TransformGroup>
            </Border.RenderTransform>
            <TextBlock x:Name="WindowStateToastText"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#132743"
                       Text="窗口状态已更新" />
        </Border>
    </Grid>
</Window>
