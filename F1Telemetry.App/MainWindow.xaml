<Window x:Class="F1Telemetry.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:attached="clr-namespace:F1Telemetry.App.AttachedProperties"
        xmlns:controls="clr-namespace:F1Telemetry.App.Views.Controls"
        xmlns:views="clr-namespace:F1Telemetry.App.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitleText}"
        Width="1380"
        Height="860"
        MinWidth="860"
        MinHeight="580"
        WindowState="Normal"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing"
        Closed="Window_Closed">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="OverviewContentTemplate">
            <views:OverviewView />
        </DataTemplate>

        <DataTemplate x:Key="ChartsContentTemplate">
            <views:ChartsView />
        </DataTemplate>

        <DataTemplate x:Key="LapHistoryContentTemplate">
            <views:LapHistoryView />
        </DataTemplate>

        <DataTemplate x:Key="PostRaceReviewContentTemplate">
            <views:PostRaceReviewView />
        </DataTemplate>

        <DataTemplate x:Key="SessionComparisonContentTemplate">
            <views:SessionComparisonView />
        </DataTemplate>

        <DataTemplate x:Key="CornerAnalysisContentTemplate">
            <views:CornerAnalysisView />
        </DataTemplate>

        <DataTemplate x:Key="OpponentsContentTemplate">
            <views:OpponentsView />
        </DataTemplate>

        <DataTemplate x:Key="LogsContentTemplate">
            <views:LogsView />
        </DataTemplate>

        <DataTemplate x:Key="AiTtsContentTemplate">
            <views:AiTtsView />
        </DataTemplate>

        <DataTemplate x:Key="SettingsContentTemplate">
            <views:SettingsView />
        </DataTemplate>

        <DataTemplate x:Key="PlaceholderContentTemplate">
            <Border Padding="24"
                    CornerRadius="20"
                    Background="#0F1B2E">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding SelectedShellNavigationTitle}"
                               TextAlignment="Center" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="16"
                               Foreground="#9AB0C9"
                               Text="将在后续里程碑拆分"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LegacyDashboardContentTemplate">
            <views:LegacyDashboardView />
        </DataTemplate>

        <Style x:Key="ShellNavigationItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#D7E4F3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Padding="14,11"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#132743" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#1D3558" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1D73F8" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#60A5FA" />
                            </Trigger>
                            <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                <Setter TargetName="ItemBorder" Property="Width" Value="44" />
                                <Setter TargetName="ItemBorder" Property="Height" Value="44" />
                                <Setter TargetName="ItemBorder" Property="Padding" Value="0" />
                                <Setter TargetName="ItemBorder" Property="HorizontalAlignment" Value="Center" />
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatusChipStyle" TargetType="{x:Type Border}">
            <Setter Property="MinHeight" Value="58" />
            <Setter Property="Padding" Value="13,10" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="CornerRadius" Value="9" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#152A45" Offset="0" />
                        <GradientStop Color="#0F1E33" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="BorderBrush" Value="#203E61" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ShellTelemetryCardStyle"
               BasedOn="{StaticResource StatusChipStyle}"
               TargetType="{x:Type Border}" />

        <Style x:Key="IconBadgeStyle" TargetType="{x:Type Border}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="#102A4B" />
            <Setter Property="BorderBrush" Value="#1C6EDC" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="ShellTelemetryIconStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Width" Value="32" />
            <Setter Property="Height" Value="32" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="#36A3FF" />
            <Setter Property="TextAlignment" Value="Center" />
        </Style>

        <Style x:Key="ShellTelemetryLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#B7C9E2" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="ShellTelemetryValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="ShellPortTextBoxStyle" TargetType="{x:Type TextBox}">
            <Setter Property="Background" Value="#0B1728" />
            <Setter Property="BorderBrush" Value="#1D3A5C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="CaretBrush" Value="#60A5FA" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style x:Key="ShellPrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#1D73F8" />
            <Setter Property="BorderBrush" Value="#3B8CFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#2B84FF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonRoot" Property="Background" Value="#1557C8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ShellSecondaryButtonStyle"
               BasedOn="{StaticResource ShellPrimaryButtonStyle}"
               TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#14243A" />
            <Setter Property="BorderBrush" Value="#294766" />
        </Style>

        <Style x:Key="PrimaryButtonStyle"
               BasedOn="{StaticResource ShellPrimaryButtonStyle}"
               TargetType="{x:Type Button}" />

        <Style x:Key="SecondaryButtonStyle"
               BasedOn="{StaticResource ShellSecondaryButtonStyle}"
               TargetType="{x:Type Button}" />

        <Style x:Key="ShellIconButtonStyle"
               BasedOn="{StaticResource ShellSecondaryButtonStyle}"
               TargetType="{x:Type Button}">
            <Setter Property="Width" Value="42" />
            <Setter Property="Height" Value="42" />
            <Setter Property="Foreground" Value="#D7E4F3" />
            <Setter Property="Background" Value="#10243C" />
            <Setter Property="BorderBrush" Value="#203E61" />
        </Style>
    </Window.Resources>
    <Grid x:Name="WindowRoot"
          Background="#08111F"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="WindowRootScaleTransform"
                            ScaleX="1"
                            ScaleY="1" />
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumnDefinition"
                              Width="{Binding DataContext.SidebarColumnWidth, ElementName=WindowRoot}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="Sidebar"
                Grid.RowSpan="2"
                CornerRadius="18"
                Background="#0F1B2E">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Margin" Value="16,16,0,16" />
                    <Setter Property="Padding" Value="14" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                            <Setter Property="Margin" Value="10,16,0,16" />
                            <Setter Property="Padding" Value="8" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Button x:Name="SidebarToggleButton"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip="展开 / 收起侧边栏">
                        <Button.Style>
                            <Style BasedOn="{StaticResource ShellIconButtonStyle}"
                                   TargetType="{x:Type Button}">
                                <Setter Property="HorizontalAlignment" Value="Right" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                        <Setter Property="HorizontalAlignment" Value="Center" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Text="&#xE700;" />
                    </Button>

                    <Border x:Name="SidebarLogo"
                            Width="120"
                            Height="96"
                            HorizontalAlignment="Center"
                            Background="#08111F"
                            CornerRadius="20">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Image Margin="10"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="Assets/AppIcon.png"
                               Stretch="Uniform" />
                    </Border>

                    <TextBlock x:Name="SidebarProductName"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="F1 Telemetry">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <ListBox x:Name="ShellNavigationList"
                         Grid.Row="1"
                         Margin="0,22,0,0"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ItemContainerStyle="{StaticResource ShellNavigationItemStyle}"
                         ItemsSource="{Binding ShellNavigationItems}"
                         SelectedItem="{Binding SelectedShellNavigationItem, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid x:Name="NavigationItemLayout"
                                  ToolTip="{Binding Name}">
                                <Grid.Style>
                                    <Style TargetType="{x:Type Grid}">
                                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                                <Setter Property="Width" Value="44" />
                                                <Setter Property="Height" Value="44" />
                                                <Setter Property="HorizontalAlignment" Value="Center" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Grid.Style>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="NavigationItemIcon"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="17"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=Foreground}"
                                           Text="{Binding IconGlyph}">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                                    <Setter Property="Grid.ColumnSpan" Value="3" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock x:Name="NavigationItemText"
                                           Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=Foreground}"
                                           Text="{Binding Name}">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border x:Name="SidebarStatusCard"
                        Grid.Row="2"
                        CornerRadius="14"
                        Background="#0B1728"
                        ToolTip="{Binding SidebarUdpStatusTooltip}">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Padding" Value="12,14" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                    <Setter Property="Padding" Value="8" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Foreground="#2DE274"
                                   Text="{Binding ConnectionStateText}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#9AB0C9"
                                   Text="{Binding SidebarUdpPortText}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <StackPanel x:Name="SidebarCompactStatusRow"
                                    HorizontalAlignment="Center"
                                    Orientation="Vertical">
                            <StackPanel.Style>
                                <Style TargetType="{x:Type StackPanel}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Ellipse x:Name="CompactSidebarStatusDot"
                                     Width="8"
                                     Height="8"
                                     HorizontalAlignment="Center"
                                     Fill="#2DE274" />
                            <TextBlock x:Name="CompactSidebarUdpLabel"
                                       Margin="0,6,0,0"
                                       HorizontalAlignment="Center"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="#9AB0C9"
                                       Text="UDP" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="TopStatusBar"
                Grid.Column="1"
                Margin="16,16,20,16"
                Padding="10"
                CornerRadius="12"
                Background="#081321"
                BorderBrush="#17304E"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <WrapPanel x:Name="TopStatusWrapPanel">
                    <Border x:Name="ConnectionStatusChip"
                            MinWidth="168"
                            MaxWidth="220"
                            Style="{StaticResource ShellTelemetryCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource IconBadgeStyle}">
                                <TextBlock Style="{StaticResource ShellTelemetryIconStyle}" Text="&#xE71B;" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource ShellTelemetryLabelStyle}" Text="连接状态" />
                                <TextBlock Style="{StaticResource ShellTelemetryValueStyle}"
                                           Text="{Binding ConnectionStateText}"
                                           ToolTip="{Binding ConnectionStateText}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="TrackStatusChip"
                            MinWidth="168"
                            MaxWidth="220"
                            Style="{StaticResource ShellTelemetryCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource IconBadgeStyle}">
                                <TextBlock Style="{StaticResource ShellTelemetryIconStyle}" Text="&#xE707;" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource ShellTelemetryLabelStyle}" Text="赛道" />
                                <TextBlock Style="{StaticResource ShellTelemetryValueStyle}"
                                           Text="{Binding TrackText}"
                                           ToolTip="{Binding TrackText}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="SessionTypeStatusChip"
                            MinWidth="168"
                            MaxWidth="220"
                            Style="{StaticResource ShellTelemetryCardStyle}"
                            ToolTip="{Binding SessionTypeTooltipText}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource IconBadgeStyle}">
                                <TextBlock Style="{StaticResource ShellTelemetryIconStyle}" Text="&#xECA7;" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource ShellTelemetryLabelStyle}" Text="赛制" />
                                <TextBlock Style="{StaticResource ShellTelemetryValueStyle}"
                                           Text="{Binding SessionTypeText}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="LapStatusChip"
                            MinWidth="168"
                            MaxWidth="220"
                            Style="{StaticResource ShellTelemetryCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource IconBadgeStyle}">
                                <TextBlock Style="{StaticResource ShellTelemetryIconStyle}" Text="&#xE7C1;" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource ShellTelemetryLabelStyle}" Text="比赛进度" />
                                <TextBlock Style="{StaticResource ShellTelemetryValueStyle}"
                                           Text="{Binding LapText}"
                                           ToolTip="{Binding LapText}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="WeatherStatusChip"
                            MinWidth="150"
                            MaxWidth="230"
                            Style="{StaticResource ShellTelemetryCardStyle}"
                            ToolTip="{Binding WeatherTooltipText}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource IconBadgeStyle}">
                                <TextBlock Style="{StaticResource ShellTelemetryIconStyle}" Text="&#xE753;" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource ShellTelemetryLabelStyle}" Text="天气" />
                                <TextBlock Style="{StaticResource ShellTelemetryValueStyle}"
                                           TextTrimming="CharacterEllipsis"
                                           Text="{Binding WeatherText}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="UdpPpsStatusChip"
                            MinWidth="128"
                            MaxWidth="170"
                            Style="{StaticResource ShellTelemetryCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="34" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource IconBadgeStyle}">
                                <TextBlock Style="{StaticResource ShellTelemetryIconStyle}" Text="&#xE9D9;" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource ShellTelemetryLabelStyle}" Text="UDP PPS" />
                                <TextBlock Style="{StaticResource ShellTelemetryValueStyle}"
                                           Text="{Binding PacketsPerSecond}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border x:Name="UdpPortStatusChip"
                            MinWidth="356"
                            Style="{StaticResource StatusChipStyle}">
                        <Grid x:Name="TopPortControlCard"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="104" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="96" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource ShellTelemetryLabelStyle}"
                                       Text="当前端口" />
                            <TextBox Grid.Column="2"
                                     Width="104"
                                     Height="30"
                                     VerticalAlignment="Center"
                                     Style="{StaticResource ShellPortTextBoxStyle}"
                                     Text="{Binding PortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="4"
                                    Width="96"
                                    Height="30"
                                    VerticalAlignment="Center"
                                    Command="{Binding StartListeningCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Content="开始监听" />
                            <Button Grid.Column="6"
                                    Width="96"
                                    Height="30"
                                    VerticalAlignment="Center"
                                    Command="{Binding StopListeningCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Content="停止监听" />
                        </Grid>
                    </Border>
                </WrapPanel>

                <TextBlock Grid.Row="2"
                           Margin="8,0,0,0"
                           Foreground="#B5C7DC"
                           Text="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding StatusMessage}"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="ShellTitleText"
                           Width="0"
                           Height="0"
                           Opacity="0"
                           Text="{Binding AppTitleText}" />
            </Grid>
        </Border>

        <ScrollViewer x:Name="ContentHostScrollViewer"
                      Grid.Row="1"
                      Grid.Column="1"
                      Margin="16,0,20,20"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="ContentHostScrollViewer_PreviewMouseWheel">
            <ContentControl x:Name="ContentHost"
                            Content="{Binding}">
                <ContentControl.Style>
                    <Style TargetType="{x:Type ContentControl}">
                        <Setter Property="ContentTemplate" Value="{StaticResource OverviewContentTemplate}" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsChartsSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource ChartsContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLapHistorySelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource LapHistoryContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsPostRaceReviewSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource PostRaceReviewContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSessionComparisonSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource SessionComparisonContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsCornerAnalysisSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource CornerAnalysisContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsOpponentsSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource OpponentsContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLogsSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource LogsContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsAiTtsSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource AiTtsContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource SettingsContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsPlaceholderNavigationSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource PlaceholderContentTemplate}" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsLegacyDashboardSelected}" Value="True">
                                <Setter Property="ContentTemplate" Value="{StaticResource LegacyDashboardContentTemplate}" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </ScrollViewer>

        <Border x:Name="WindowStateToast"
                Grid.ColumnSpan="2"
                Grid.RowSpan="2"
                Margin="0,24,24,0"
                Padding="14,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="20"
                Background="#E6EEF9"
                BorderBrush="#BDD0EA"
                BorderThickness="1"
                CornerRadius="14"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="WindowStateToastScaleTransform"
                                    ScaleX="0.96"
                                    ScaleY="0.96" />
                    <TranslateTransform x:Name="WindowStateToastTranslateTransform"
                                        Y="-6" />
                </TransformGroup>
            </Border.RenderTransform>
            <TextBlock x:Name="WindowStateToastText"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#132743"
                       Text="窗口状态已更新" />
        </Border>
    </Grid>
</Window>
