<Window x:Class="F1Telemetry.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:attached="clr-namespace:F1Telemetry.App.AttachedProperties"
        xmlns:controls="clr-namespace:F1Telemetry.App.Views.Controls"
        xmlns:views="clr-namespace:F1Telemetry.App.Views"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding AppTitleText}"
        Width="1380"
        Height="860"
        MinWidth="920"
        MinHeight="620"
        MaxWidth="1920"
        MaxHeight="1080"
        WindowState="Normal"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        UseLayoutRounding="True"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing"
        Closed="Window_Closed">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <DataTemplate x:Key="OverviewContentTemplate">
            <views:OverviewView />
        </DataTemplate>

        <DataTemplate x:Key="ChartsContentTemplate">
            <views:ChartsView />
        </DataTemplate>

        <DataTemplate x:Key="LapHistoryContentTemplate">
            <views:LapHistoryView />
        </DataTemplate>

        <DataTemplate x:Key="PostRaceReviewContentTemplate">
            <views:PostRaceReviewView />
        </DataTemplate>

        <DataTemplate x:Key="SessionComparisonContentTemplate">
            <views:SessionComparisonView />
        </DataTemplate>

        <DataTemplate x:Key="OpponentsContentTemplate">
            <views:OpponentsView />
        </DataTemplate>

        <DataTemplate x:Key="LogsContentTemplate">
            <views:LogsView />
        </DataTemplate>

        <DataTemplate x:Key="AiTtsContentTemplate">
            <views:AiTtsView />
        </DataTemplate>

        <DataTemplate x:Key="SettingsContentTemplate">
            <views:SettingsView />
        </DataTemplate>

        <DataTemplate x:Key="PlaceholderContentTemplate">
            <Border Padding="24"
                    CornerRadius="20"
                    Background="#0F1B2E">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding SelectedShellNavigationTitle}"
                               TextAlignment="Center" />
                    <TextBlock Margin="0,12,0,0"
                               FontSize="16"
                               Foreground="#9AB0C9"
                               Text="将在后续里程碑拆分"
                               TextAlignment="Center" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="LegacyDashboardContentTemplate">
            <views:LegacyDashboardView />
        </DataTemplate>

        <Style x:Key="ShellNavigationItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Foreground" Value="#D7E4F3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="ItemBorder"
                                Padding="14,11"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="12">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#132743" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#1D3558" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1557A9" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#2387F8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="WindowRoot"
          Background="#08111F"
          RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="WindowRootScaleTransform"
                            ScaleX="1"
                            ScaleY="1" />
        </Grid.RenderTransform>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumnDefinition"
                              Width="{Binding DataContext.SidebarColumnWidth, ElementName=WindowRoot}" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="Sidebar"
                Grid.RowSpan="2"
                CornerRadius="18"
                Background="#0F1B2E">
            <Border.Style>
                <Style TargetType="{x:Type Border}">
                    <Setter Property="Margin" Value="16,16,0,16" />
                    <Setter Property="Padding" Value="14" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                            <Setter Property="Margin" Value="10,16,0,16" />
                            <Setter Property="Padding" Value="8" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <Button x:Name="SidebarToggleButton"
                            Width="34"
                            Height="34"
                            HorizontalAlignment="Right"
                            Command="{Binding ToggleSidebarCommand}"
                            ToolTip="展开 / 收起侧边栏">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   FontSize="15"
                                   Text="&#xE700;" />
                    </Button>

                    <Border x:Name="SidebarLogo"
                            Width="120"
                            Height="96"
                            HorizontalAlignment="Center"
                            Background="#08111F"
                            CornerRadius="20">
                        <Border.Style>
                            <Style TargetType="{x:Type Border}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Image Margin="10"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Source="Assets/AppIcon.png"
                               Stretch="Uniform" />
                    </Border>

                    <TextBlock x:Name="SidebarProductName"
                               Margin="0,4,0,0"
                               HorizontalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="F1 Telemetry">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <ListBox x:Name="ShellNavigationList"
                         Grid.Row="1"
                         Margin="0,22,0,0"
                         Background="Transparent"
                         BorderThickness="0"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ItemContainerStyle="{StaticResource ShellNavigationItemStyle}"
                         ItemsSource="{Binding ShellNavigationItems}"
                         SelectedItem="{Binding SelectedShellNavigationItem, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid ToolTip="{Binding Name}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="10" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="17"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=Foreground}"
                                           Text="{Binding IconGlyph}" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=Foreground}"
                                           Text="{Binding Name}">
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Border Grid.Row="2"
                        Padding="12,14"
                        CornerRadius="14"
                        Background="#0B1728"
                        ToolTip="{Binding SidebarUdpStatusTooltip}">
                    <StackPanel>
                        <TextBlock Foreground="#2DE274"
                                   Text="{Binding ConnectionStateText}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#9AB0C9"
                                   Text="{Binding SidebarUdpPortText}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#9AB0C9"
                                   Text="UDP">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border x:Name="TopStatusBar"
                Grid.Column="1"
                Margin="16,16,20,16"
                Padding="22"
                CornerRadius="22"
                Background="#0F1B2E">
            <StackPanel>
                <TextBlock x:Name="ShellTitleText"
                           FontSize="30"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="{Binding AppTitleText}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#9AB0C9"
                           Text="{Binding Subtitle}"
                           TextWrapping="Wrap" />

                <WrapPanel Margin="0,18,0,0">
                    <Border Margin="0,0,12,10" Padding="12,8" CornerRadius="14" Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="连接状态" />
                            <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding ConnectionStateText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,10" Padding="12,8" CornerRadius="14" Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="赛道" />
                            <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding TrackText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,10" Padding="12,8" CornerRadius="14" Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="赛制" />
                            <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding SessionTypeText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,10" Padding="12,8" CornerRadius="14" Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="比赛进度" />
                            <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding LapText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,10" Padding="12,8" CornerRadius="14" Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="天气" />
                            <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding WeatherText}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,10" Padding="12,8" CornerRadius="14" Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="UDP PPS" />
                            <TextBlock Margin="0,4,0,0" Foreground="White" Text="{Binding PacketsPerSecond}" />
                        </StackPanel>
                    </Border>
                    <Border Margin="0,0,12,10" Padding="12,8" CornerRadius="14" Background="#132743">
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       Foreground="#7FA5D8"
                                       Text="监听端口" />
                            <TextBox Width="120"
                                     Margin="0,0,10,0"
                                     Padding="10,6"
                                     Text="{Binding PortText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Width="108"
                                    Height="36"
                                    Margin="0,0,10,0"
                                    Command="{Binding StartListeningCommand}"
                                    Content="开始监听" />
                            <Button Width="108"
                                    Height="36"
                                    Command="{Binding StopListeningCommand}"
                                    Content="停止监听" />
                        </WrapPanel>
                    </Border>
                </WrapPanel>

                <TextBlock Margin="0,4,0,0"
                           Foreground="#B5C7DC"
                           Text="{Binding StatusMessage}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Border>

        <ContentControl x:Name="ContentHost"
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="16,0,20,20"
                        ClipToBounds="True"
                        Content="{Binding}">
            <ContentControl.Style>
                <Style TargetType="{x:Type ContentControl}">
                    <Setter Property="ContentTemplate" Value="{StaticResource OverviewContentTemplate}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsChartsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource ChartsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLapHistorySelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource LapHistoryContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsPostRaceReviewSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource PostRaceReviewContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSessionComparisonSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource SessionComparisonContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsOpponentsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource OpponentsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLogsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource LogsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsAiTtsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource AiTtsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsSettingsSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource SettingsContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsPlaceholderNavigationSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource PlaceholderContentTemplate}" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsLegacyDashboardSelected}" Value="True">
                            <Setter Property="ContentTemplate" Value="{StaticResource LegacyDashboardContentTemplate}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <Border x:Name="WindowStateToast"
                Grid.ColumnSpan="2"
                Grid.RowSpan="2"
                Margin="0,24,24,0"
                Padding="14,10"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Panel.ZIndex="20"
                Background="#E6EEF9"
                BorderBrush="#BDD0EA"
                BorderThickness="1"
                CornerRadius="14"
                IsHitTestVisible="False"
                Opacity="0"
                Visibility="Collapsed">
            <Border.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="WindowStateToastScaleTransform"
                                    ScaleX="0.96"
                                    ScaleY="0.96" />
                    <TranslateTransform x:Name="WindowStateToastTranslateTransform"
                                        Y="-6" />
                </TransformGroup>
            </Border.RenderTransform>
            <TextBlock x:Name="WindowStateToastText"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="#132743"
                       Text="窗口状态已更新" />
        </Border>
    </Grid>
</Window>
