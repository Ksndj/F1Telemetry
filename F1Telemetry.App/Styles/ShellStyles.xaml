<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:shell="clr-namespace:F1Telemetry.App.Views.Shell"
                    xmlns:views="clr-namespace:F1Telemetry.App.Views"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="OverviewContentTemplate">
        <views:OverviewView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="ChartsContentTemplate">
        <views:ChartsView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="LapHistoryContentTemplate">
        <views:LapHistoryView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="PostRaceReviewContentTemplate">
        <views:PostRaceReviewView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="SessionComparisonContentTemplate">
        <views:SessionComparisonView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="CornerAnalysisContentTemplate">
        <views:CornerAnalysisView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="OpponentsContentTemplate">
        <views:OpponentsView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="LogsContentTemplate">
        <views:LogsView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="AiTtsContentTemplate">
        <views:AiTtsView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="SettingsContentTemplate">
        <views:SettingsView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <DataTemplate x:Key="PlaceholderContentTemplate">
        <Border Padding="24"
                CornerRadius="20"
                Background="{StaticResource BgPanelBrush}"
                DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                <TextBlock FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FgPrimaryBrush}"
                           Text="{Binding SelectedShellNavigationTitle}"
                           TextAlignment="Center" />
                <TextBlock Margin="0,12,0,0"
                           FontSize="16"
                           Foreground="{StaticResource FgSectionBrush}"
                           Text="将在后续里程碑拆分"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </DataTemplate>

    <DataTemplate x:Key="LegacyDashboardContentTemplate">
        <views:LegacyDashboardView DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" />
    </DataTemplate>

    <shell:NavigationTemplateSelector x:Key="ShellNavigationTemplateSelector"
                                      OverviewTemplate="{StaticResource OverviewContentTemplate}"
                                      ChartsTemplate="{StaticResource ChartsContentTemplate}"
                                      LapHistoryTemplate="{StaticResource LapHistoryContentTemplate}"
                                      PostRaceReviewTemplate="{StaticResource PostRaceReviewContentTemplate}"
                                      SessionComparisonTemplate="{StaticResource SessionComparisonContentTemplate}"
                                      CornerAnalysisTemplate="{StaticResource CornerAnalysisContentTemplate}"
                                      OpponentsTemplate="{StaticResource OpponentsContentTemplate}"
                                      LogsTemplate="{StaticResource LogsContentTemplate}"
                                      AiTtsTemplate="{StaticResource AiTtsContentTemplate}"
                                      SettingsTemplate="{StaticResource SettingsContentTemplate}"
                                      LegacyDashboardTemplate="{StaticResource LegacyDashboardContentTemplate}"
                                      PlaceholderTemplate="{StaticResource PlaceholderContentTemplate}" />
</ResourceDictionary>
