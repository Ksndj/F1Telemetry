<UserControl x:Class="F1Telemetry.App.Views.PostRaceReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:F1Telemetry.App.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="SectionCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="#111F35" />
        </Style>

        <Style x:Key="InnerCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Background" Value="#132743" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#9AB0C9" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LabelTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#7FA5D8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="ValueTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Margin" Value="0,6,0,0" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <DataTemplate x:Key="HistorySessionTemplate">
            <Border Margin="0,0,0,10"
                    Style="{StaticResource InnerCardStyle}">
                <StackPanel>
                    <TextBlock FontWeight="SemiBold"
                               Foreground="White"
                               Text="{Binding SummaryText}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,6,0,0"
                               Style="{StaticResource MutedTextStyle}"
                               Text="{Binding TrackText}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#6F86A3"
                               Text="{Binding SessionTypeText}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#6F86A3"
                               Text="{Binding StartedAtText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MetricTemplate">
            <Border Margin="0,0,10,10"
                    MinWidth="150"
                    Style="{StaticResource InnerCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource LabelTextStyle}"
                               Text="{Binding Label}" />
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Style="{StaticResource ValueTextStyle}"
                               Text="{Binding ValueText}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#6F86A3"
                               Text="{Binding DetailText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StintTemplate">
            <Border Margin="0,0,0,10"
                    Style="{StaticResource InnerCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelTextStyle}"
                                   Text="{Binding StintText}" />
                        <TextBlock Style="{StaticResource ValueTextStyle}"
                                   Text="{Binding TyreText}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Foreground="#D7E4F3"
                               Text="{Binding SummaryText}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TimelineTemplate">
            <Border Margin="0,0,0,10"
                    Style="{StaticResource InnerCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelTextStyle}"
                               Text="{Binding LapText}" />
                    <TextBlock Grid.Column="1"
                               Foreground="#D7E4F3"
                               Text="{Binding Category}" />
                    <TextBlock Grid.Column="2"
                               Foreground="White"
                               Text="{Binding Message}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AiReportTemplate">
            <Border Margin="0,0,0,10"
                    Style="{StaticResource InnerCardStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="{Binding Title}"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   Foreground="#7FA5D8"
                                   Text="{Binding GeneratedAtText}"
                                   TextWrapping="Wrap" />
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="#D7E4F3"
                               Text="{Binding SummaryText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer x:Name="PostRaceReviewScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <Border MinWidth="1120"
                Padding="20"
                CornerRadius="20"
                Background="#0F1B2E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="330" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" MinWidth="760" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource SectionCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="历史赛后复盘" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="这里查看已保存的历史 UDP 会话复盘，不反映当前正在接收的实时 UDP 会话。选择历史会话后，右侧内容会切换到对应记录。" />
                        </StackPanel>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding PostRaceReview.StatusText, TargetNullValue=等待选择历史会话。}" />
                            <Button Grid.Column="1"
                                    Width="104"
                                    Height="34"
                                    HorizontalAlignment="Right"
                                    Command="{Binding PostRaceReview.RefreshCommand}"
                                    Content="刷新历史" />
                        </Grid>

                        <TextBlock Grid.Row="4"
                                   Margin="0,0,0,10"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding PostRaceReview.EmptyStateText}" />

                        <ListBox Grid.Row="4"
                                 Margin="0,36,0,0"
                                 MinHeight="360"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 HorizontalContentAlignment="Stretch"
                                 ItemTemplate="{StaticResource HistorySessionTemplate}"
                                 ItemsSource="{Binding PostRaceReview.HistoryBrowser.HistorySessions}"
                                 SelectedItem="{Binding PostRaceReview.HistoryBrowser.SelectedSession, Mode=TwoWay}" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="2">
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="280" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionTitleStyle}"
                                               Text="Session Summary / metrics" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding PostRaceReview.HistoryBrowser.SelectedSession.SummaryText, TargetNullValue=请选择左侧历史会话查看赛后摘要。}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1"
                                            HorizontalAlignment="Right">
                                    <StackPanel HorizontalAlignment="Right"
                                                Orientation="Horizontal">
                                        <Button Width="118"
                                                Height="34"
                                                Command="{Binding PostRaceReview.ExportMarkdownCommand}"
                                                Content="导出 Markdown" />
                                        <Button Width="104"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Command="{Binding PostRaceReview.ExportJsonCommand}"
                                                Content="导出 JSON" />
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               HorizontalAlignment="Right"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding PostRaceReview.ReportExportStatusText}"
                                               TextAlignment="Right" />
                                    <Border Margin="0,8,0,0"
                                            Padding="12,7"
                                            HorizontalAlignment="Right"
                                            CornerRadius="12"
                                            Background="#19365A"
                                            Visibility="{Binding PostRaceReview.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Foreground="#D7E4F3"
                                                   Text="正在加载历史数据" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <ItemsControl Margin="0,16,0,0"
                                          ItemTemplate="{StaticResource MetricTemplate}"
                                          ItemsSource="{Binding PostRaceReview.SummaryMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Margin="0,16,0,0"
                            Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="趋势图表" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="图表来自所选历史会话，用于赛后复盘，不随当前实时 UDP 数据刷新。" />

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="260" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="260" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="260" />
                                </Grid.RowDefinitions>

                                <controls:TelemetryChartControl DataContext="{Binding PostRaceReview.LapTimeTrendPanel}" />
                                <controls:TelemetryChartControl Grid.Column="2"
                                                                DataContext="{Binding PostRaceReview.SectorTrendPanel}" />
                                <controls:TelemetryChartControl Grid.Row="2"
                                                                DataContext="{Binding PostRaceReview.FuelTrendPanel}" />
                                <controls:TelemetryChartControl Grid.Row="2"
                                                                Grid.Column="2"
                                                                DataContext="{Binding PostRaceReview.ErsTrendPanel}" />
                                <controls:TelemetryChartControl Grid.Row="4"
                                                                Grid.ColumnSpan="3"
                                                                DataContext="{Binding PostRaceReview.TyreWearTrendPanel}" />
                            </Grid>

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding PostRaceReview.TyreWearStatusText}" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="轮胎与 stint 摘要" />
                                <ItemsControl Margin="0,14,0,0"
                                              ItemTemplate="{StaticResource StintTemplate}"
                                              ItemsSource="{Binding PostRaceReview.StintSummaries}" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitleStyle}"
                                           Text="事件时间线" />
                                <ItemsControl Margin="0,14,0,0"
                                              ItemTemplate="{StaticResource TimelineTemplate}"
                                              ItemsSource="{Binding PostRaceReview.EventTimeline}" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Margin="0,16,0,0"
                            Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleStyle}"
                                       Text="AI reports" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="所选历史会话的赛后 AI 报告。" />
                            <ItemsControl Margin="0,14,0,0"
                                          ItemTemplate="{StaticResource AiReportTemplate}"
                                          ItemsSource="{Binding PostRaceReview.AiReports}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </ScrollViewer>
</UserControl>
