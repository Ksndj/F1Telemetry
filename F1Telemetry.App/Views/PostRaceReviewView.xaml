<UserControl x:Class="F1Telemetry.App.Views.PostRaceReviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:attached="clr-namespace:F1Telemetry.App.AttachedProperties"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:F1Telemetry.App.Views.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PostRaceHistorySessionItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="SessionItemChrome"
                                Padding="2"
                                Background="{StaticResource TransparentBrush}"
                                BorderBrush="{StaticResource TransparentBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SessionItemChrome" Property="Background" Value="{StaticResource BgListItemHoverBrush}" />
                                <Setter TargetName="SessionItemChrome" Property="BorderBrush" Value="{StaticResource BorderListItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="SessionItemChrome" Property="Background" Value="{StaticResource BgListItemSelectedBrush}" />
                                <Setter TargetName="SessionItemChrome" Property="BorderBrush" Value="{StaticResource BorderListItemSelectedBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="SessionItemChrome" Property="BorderBrush" Value="{StaticResource AccentPrimaryFocusBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="HistorySessionTemplate">
            <Border x:Name="PostRaceHistorySessionCard"
                    Margin="0,0,0,10"
                    Style="{StaticResource MetricTileStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="68" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="{Binding SummaryText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding TrackText}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource FgMutedBrush}"
                                   Text="{Binding SessionTypeText}"
                                   TextWrapping="Wrap" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource FgMutedBrush}"
                                   Text="{Binding StartedAtText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="58"
                            Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Command="{Binding DataContext.PostRaceReview.HistoryBrowser.DeleteSessionCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                            CommandParameter="{Binding}"
                            Content="删除"
                            IsEnabled="{Binding CanDelete}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MetricTemplate">
            <Border x:Name="PostRaceMetricCard"
                    Margin="0,0,10,10"
                    Width="150"
                    Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource LabelTextStyle}"
                               Text="{Binding Label}" />
                    <TextBlock FontSize="16"
                               FontWeight="SemiBold"
                               Style="{StaticResource ValueTextStyle}"
                               Text="{Binding ValueText}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="{StaticResource FgMutedBrush}"
                               Text="{Binding DetailText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StintTemplate">
            <Border Margin="0,0,0,10"
                    Style="{StaticResource MetricTileStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Style="{StaticResource LabelTextStyle}"
                                   Text="{Binding StintText}" />
                        <TextBlock Style="{StaticResource ValueTextStyle}"
                                   Text="{Binding TyreText}" />
                    </StackPanel>
                    <TextBlock Grid.Column="1"
                               Foreground="{StaticResource FgSecondaryBrush}"
                               Text="{Binding SummaryText}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TimelineTemplate">
            <Border Margin="0,0,0,10"
                    Style="{StaticResource MetricTileStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="84" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource LabelTextStyle}"
                               Text="{Binding LapText}" />
                    <TextBlock Grid.Column="1"
                               Foreground="{StaticResource FgSecondaryBrush}"
                               Text="{Binding Category}" />
                    <TextBlock Grid.Column="2"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               Text="{Binding Message}"
                               TextWrapping="Wrap" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="AiReportTemplate">
            <Border Margin="0,0,0,10"
                    Style="{StaticResource MetricTileStyle}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="{Binding Title}"
                                   TextWrapping="Wrap" />
                        <TextBlock Grid.Column="1"
                                   HorizontalAlignment="Right"
                                   Foreground="{StaticResource FgLabelBrush}"
                                   Text="{Binding GeneratedAtText}"
                                   TextWrapping="Wrap" />
                    </Grid>
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource FgSecondaryBrush}"
                               Text="{Binding SummaryText}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{StaticResource FgSectionBrush}"
                               Text="{Binding DetailReportText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Border Padding="20"
            CornerRadius="20"
            Background="{StaticResource BgPanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="PostRaceHistoryPanel"
                        Style="{StaticResource GlassCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid x:Name="PostRaceHistoryHeader"
                              Style="{StaticResource SectionHeaderStyle}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource IconBadgeStyle}">
                                <TextBlock Style="{StaticResource IconTextStyle}"
                                           Text="&#xE7C1;" />
                            </Border>
                            <StackPanel Grid.Column="2">
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                           Text="赛后复盘" />
                                <TextBlock Margin="0,5,0,0"
                                           Style="{StaticResource BodyTextStyle}"
                                           Text="回顾已保存的历史 UDP 会话，分析关键数据与事件，生成复盘报告。" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="116" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding PostRaceReview.StatusText, TargetNullValue=等待选择历史会话。}" />
                            <Button Grid.Column="1"
                                    Width="104"
                                    Height="34"
                                    HorizontalAlignment="Right"
                                    Command="{Binding PostRaceReview.RefreshCommand}"
                                    Content="刷新历史"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                        </Grid>

                        <TextBlock Grid.Row="4"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding PostRaceReview.EmptyStateText}" />

                        <Grid x:Name="PostRaceHistorySessionListHost"
                              Grid.Row="6"
                              attached:AdaptivePageSizeBehavior.PagedCollection="{Binding PostRaceReview.HistoryBrowser.HistorySessionPages}"
                              attached:AdaptivePageSizeBehavior.EstimatedItemHeight="118"
                              attached:AdaptivePageSizeBehavior.MinPageSize="2"
                              attached:AdaptivePageSizeBehavior.MaxPageSize="8"
                              ClipToBounds="True">
                            <ListBox x:Name="PostRaceHistorySessionListBox"
                                     Background="{StaticResource TransparentBrush}"
                                     BorderThickness="0"
                                     HorizontalContentAlignment="Stretch"
                                     ItemContainerStyle="{StaticResource PostRaceHistorySessionItemStyle}"
                                     ItemTemplate="{StaticResource HistorySessionTemplate}"
                                     ItemsSource="{Binding PostRaceReview.HistoryBrowser.HistorySessionPages.Items}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                                     SelectedItem="{Binding PostRaceReview.HistoryBrowser.SelectedSession, Mode=TwoWay}" />
                        </Grid>

                        <StackPanel Grid.Row="8"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal">
                            <Button Width="68"
                                    Height="30"
                                    Command="{Binding PostRaceReview.HistoryBrowser.HistorySessionPages.PreviousPageCommand}"
                                    Content="上一页"
                                    Style="{StaticResource SecondaryButtonStyle}" />
                            <TextBlock Margin="10,0"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding PostRaceReview.HistoryBrowser.HistorySessionPages.PageText}" />
                            <Button Width="68"
                                    Height="30"
                                    Command="{Binding PostRaceReview.HistoryBrowser.HistorySessionPages.NextPageCommand}"
                                    Content="下一页"
                                    Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Column="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                    <Border x:Name="PostRaceSummaryPanel"
                            Style="{StaticResource GlassCardStyle}">
                        <StackPanel>
                            <Grid x:Name="PostRaceSummaryHeader"
                                  Style="{StaticResource SectionHeaderStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="280" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource IconBadgeStyle}">
                                    <TextBlock Style="{StaticResource IconTextStyle}"
                                               Text="&#xE9D2;" />
                                </Border>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="Session Summary / metrics" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="{Binding PostRaceReview.HistoryBrowser.SelectedSession.SummaryText, TargetNullValue=请选择左侧历史会话查看赛后摘要。}" />
                                </StackPanel>
                                <StackPanel Grid.Column="3"
                                            HorizontalAlignment="Right">
                                    <StackPanel HorizontalAlignment="Right"
                                                Orientation="Horizontal">
                                        <Button Width="118"
                                                Height="34"
                                                Command="{Binding PostRaceReview.ExportMarkdownCommand}"
                                                Content="导出 Markdown"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                        <Button Width="104"
                                                Height="34"
                                                Margin="8,0,0,0"
                                                Command="{Binding PostRaceReview.ExportJsonCommand}"
                                                Content="导出 JSON"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                    </StackPanel>
                                    <TextBlock Margin="0,8,0,0"
                                               HorizontalAlignment="Right"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding PostRaceReview.ReportExportStatusText}"
                                               TextAlignment="Right" />
                                    <Border Margin="0,8,0,0"
                                            Padding="12,7"
                                            HorizontalAlignment="Right"
                                            CornerRadius="12"
                                            Background="{StaticResource BgLoadingBadgeBrush}"
                                            Visibility="{Binding PostRaceReview.IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <TextBlock Foreground="{StaticResource FgSecondaryBrush}"
                                                   Text="正在加载历史数据" />
                                    </Border>
                                </StackPanel>
                            </Grid>

                            <ItemsControl Margin="0,16,0,0"
                                          ItemTemplate="{StaticResource MetricTemplate}"
                                          ItemsSource="{Binding PostRaceReview.SummaryMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border x:Name="PostRaceTrendChartsPanel"
                            Margin="0,16,0,0"
                            Style="{StaticResource GlassCardStyle}">
                        <StackPanel>
                            <Grid x:Name="PostRaceChartsHeader"
                                  Style="{StaticResource SectionHeaderStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource IconBadgeStyle}">
                                    <TextBlock Style="{StaticResource IconTextStyle}"
                                               Text="&#xE9D9;" />
                                </Border>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="趋势图表" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="图表来自所选历史会话，用于赛后复盘，不随当前实时 UDP 数据刷新。" />
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,16,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="260" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="260" />
                                    <RowDefinition Height="14" />
                                    <RowDefinition Height="260" />
                                </Grid.RowDefinitions>

                                <controls:TelemetryChartControl DataContext="{Binding PostRaceReview.LapTimeTrendPanel}" />
                                <controls:TelemetryChartControl Grid.Column="2"
                                                                DataContext="{Binding PostRaceReview.SectorTrendPanel}" />
                                <controls:TelemetryChartControl Grid.Row="2"
                                                                DataContext="{Binding PostRaceReview.FuelTrendPanel}" />
                                <controls:TelemetryChartControl Grid.Row="2"
                                                                Grid.Column="2"
                                                                DataContext="{Binding PostRaceReview.ErsTrendPanel}" />
                                <controls:TelemetryChartControl Grid.Row="4"
                                                                Grid.ColumnSpan="3"
                                                                DataContext="{Binding PostRaceReview.TyreWearTrendPanel}" />
                            </Grid>

                            <TextBlock Margin="0,12,0,0"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding PostRaceReview.TyreWearStatusText}" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border x:Name="PostRaceStintSummaryPanel"
                                Style="{StaticResource GlassCardStyle}">
                            <StackPanel>
                                <Grid Style="{StaticResource SectionHeaderStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource IconBadgeStyle}">
                                        <TextBlock Style="{StaticResource IconTextStyle}"
                                                   Text="&#xE8B7;" />
                                    </Border>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource SectionTitleTextStyle}"
                                               Text="轮胎与 stint 摘要" />
                                </Grid>
                                <ItemsControl Margin="0,14,0,0"
                                              ItemTemplate="{StaticResource StintTemplate}"
                                              ItemsSource="{Binding PostRaceReview.StintSummaries}" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="PostRaceEventTimelineHost"
                                Grid.Column="2"
                                attached:AdaptivePageSizeBehavior.PagedCollection="{Binding PostRaceReview.EventTimelinePages}"
                                attached:AdaptivePageSizeBehavior.EstimatedItemHeight="64"
                                attached:AdaptivePageSizeBehavior.ChromeHeight="70"
                                attached:AdaptivePageSizeBehavior.MinPageSize="3"
                                attached:AdaptivePageSizeBehavior.MaxPageSize="12"
                                Style="{StaticResource GlassCardStyle}">
                            <StackPanel>
                                <Grid Style="{StaticResource SectionHeaderStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Style="{StaticResource IconBadgeStyle}">
                                        <TextBlock Style="{StaticResource IconTextStyle}"
                                                   Text="&#xE121;" />
                                    </Border>
                                    <TextBlock Grid.Column="2"
                                               Style="{StaticResource SectionTitleTextStyle}"
                                               Text="事件时间线" />
                                </Grid>
                                <ItemsControl Margin="0,14,0,0"
                                              ItemTemplate="{StaticResource TimelineTemplate}"
                                              ItemsSource="{Binding PostRaceReview.EventTimelinePages.Items}" />
                                <StackPanel Margin="0,4,0,0"
                                            HorizontalAlignment="Right"
                                            Orientation="Horizontal">
                                    <Button Width="68"
                                            Height="30"
                                            Command="{Binding PostRaceReview.EventTimelinePages.PreviousPageCommand}"
                                            Content="上一页"
                                            Style="{StaticResource SecondaryButtonStyle}" />
                                    <TextBlock Margin="10,0"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding PostRaceReview.EventTimelinePages.PageText}" />
                                    <Button Width="68"
                                            Height="30"
                                            Command="{Binding PostRaceReview.EventTimelinePages.NextPageCommand}"
                                            Content="下一页"
                                            Style="{StaticResource PrimaryButtonStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border x:Name="PostRaceAiReportHost"
                            Margin="0,16,0,0"
                            attached:AdaptivePageSizeBehavior.PagedCollection="{Binding PostRaceReview.AiReportPages}"
                            attached:AdaptivePageSizeBehavior.EstimatedItemHeight="92"
                            attached:AdaptivePageSizeBehavior.ChromeHeight="76"
                            attached:AdaptivePageSizeBehavior.MinPageSize="2"
                            attached:AdaptivePageSizeBehavior.MaxPageSize="8"
                            Style="{StaticResource GlassCardStyle}">
                        <StackPanel>
                            <Grid x:Name="PostRaceAiReportHeader"
                                  Style="{StaticResource SectionHeaderStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource IconBadgeStyle}">
                                    <TextBlock Style="{StaticResource IconTextStyle}"
                                               Text="&#xE90F;" />
                                </Border>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                               Text="AI reports" />
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource BodyTextStyle}"
                                               Text="所选历史会话的赛后 AI 报告。" />
                                </StackPanel>
                            </Grid>
                            <ItemsControl Margin="0,14,0,0"
                                          ItemTemplate="{StaticResource AiReportTemplate}"
                                          ItemsSource="{Binding PostRaceReview.AiReportPages.Items}" />
                            <StackPanel Margin="0,4,0,0"
                                        HorizontalAlignment="Right"
                                        Orientation="Horizontal">
                                <Button Width="68"
                                        Height="30"
                                        Command="{Binding PostRaceReview.AiReportPages.PreviousPageCommand}"
                                        Content="上一页"
                                        Style="{StaticResource SecondaryButtonStyle}" />
                                <TextBlock Margin="10,0"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding PostRaceReview.AiReportPages.PageText}" />
                                <Button Width="68"
                                        Height="30"
                                        Command="{Binding PostRaceReview.AiReportPages.NextPageCommand}"
                                        Content="下一页"
                                        Style="{StaticResource PrimaryButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
    </Border>
</UserControl>
