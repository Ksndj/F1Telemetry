<UserControl x:Class="F1Telemetry.App.Views.LegacyDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:attached="clr-namespace:F1Telemetry.App.AttachedProperties"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="1120">
    <Grid x:Name="LegacyDashboardRoot">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="220" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border Padding="20" CornerRadius="20" Background="{StaticResource BgPanelBrush}">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               Text="玩家实时卡片" />

                    <Border Margin="0,18,0,0" Padding="16" CornerRadius="16" Background="{StaticResource BgCardBrush}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="车手" />
                            <TextBlock Margin="0,6,0,0" FontSize="18" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerName}" />
                        </StackPanel>
                    </Border>

                    <UniformGrid Margin="0,16,0,0" Columns="2">
                        <Border Margin="0,0,8,8" Padding="14" CornerRadius="14" Background="{StaticResource BgCardInnerBrush}">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="当前圈" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerCurrentLapText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,0,0,8" Padding="14" CornerRadius="14" Background="{StaticResource BgCardInnerBrush}">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="位置" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerPositionText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="0,8,8,8" Padding="14" CornerRadius="14" Background="{StaticResource BgCardInnerBrush}">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="上圈" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerLastLapText}" />
                            </StackPanel>
                        </Border>
                        <Border Margin="8,8,0,8" Padding="14" CornerRadius="14" Background="{StaticResource BgCardInnerBrush}">
                            <StackPanel>
                                <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="最佳圈" />
                                <TextBlock Margin="0,6,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerBestLapText}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Margin="0,8,0,0" Padding="16" CornerRadius="16" Background="{StaticResource BgCardBrush}">
                        <StackPanel>
                            <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="前后车差距" />
                            <TextBlock Margin="0,6,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerGapText}" />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,12,0,0" Padding="16" CornerRadius="16" Background="{StaticResource BgCardBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="96" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="燃油" />
                            <TextBlock Grid.Column="1" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerFuelText}" />

                            <TextBlock Grid.Row="1" Margin="0,12,0,0" Foreground="{StaticResource FgLabelBrush}" Text="ERS" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,12,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerErsText}" />

                            <TextBlock Grid.Row="2" Margin="0,12,0,0" Foreground="{StaticResource FgLabelBrush}" Text="当前轮胎" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,12,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerTyreText}" />

                            <TextBlock Grid.Row="3" Margin="0,12,0,0" Foreground="{StaticResource FgLabelBrush}" Text="胎龄" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,12,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding PlayerTyreAgeText}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Padding="20" CornerRadius="20" Background="{StaticResource BgPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="320" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="AI 分析播报" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource FgSectionBrush}"
                                   Text="速度、输入、燃油和胎磨趋势进入 AI 短分析，由 TTS 播报关键结论。" />
                    </StackPanel>

                    <Grid Grid.Row="1" Margin="0,18,0,0">
                        <ItemsControl ItemsSource="{Binding AiTtsLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,8"
                                            Padding="10"
                                            CornerRadius="10"
                                            Background="{StaticResource BgCardBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="74" />
                                                <ColumnDefinition Width="62" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="{Binding Timestamp}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{StaticResource FgSecondaryBrush}"
                                                       Text="{Binding Category}" />
                                            <TextBlock Grid.Column="2"
                                                       Foreground="{StaticResource FgPrimaryBrush}"
                                                       Text="{Binding Message}"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                    <StackPanel Grid.Row="3">
                        <TextBlock FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="单圈历史" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource FgSectionBrush}"
                                   Text="缓存保留整场圈摘要，界面默认显示最近 12 圈，最新圈在最上方。" />

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="12" CornerRadius="14" Background="{StaticResource BgCardBrush}">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="Best" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource FgPrimaryBrush}"
                                               Text="{Binding BestLapSummaryText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="2" Padding="12" CornerRadius="14" Background="{StaticResource BgCardBrush}">
                                <StackPanel>
                                    <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="Last" />
                                    <TextBlock Margin="0,6,0,0"
                                               Foreground="{StaticResource FgPrimaryBrush}"
                                               Text="{Binding LastLapSummaryText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>

                    <ListView Grid.Row="4"
                              Margin="0,18,0,0"
                              Background="{StaticResource TransparentBrush}"
                              BorderThickness="0"
                              ItemsSource="{Binding RecentLapSummaries}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        CornerRadius="14"
                                        Background="{StaticResource BgCardBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="92" />
                                            <ColumnDefinition Width="170" />
                                            <ColumnDefinition Width="88" />
                                            <ColumnDefinition Width="74" />
                                            <ColumnDefinition Width="74" />
                                            <ColumnDefinition Width="76" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="96" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding LapText}" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding LapTimeText}" />
                                        <TextBlock Grid.Column="2" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding SectorsText}" />
                                        <TextBlock Grid.Column="3" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding AverageSpeedText}" />
                                        <TextBlock Grid.Column="4" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding FuelUsedLitresText}" />
                                        <TextBlock Grid.Column="5" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding ErsUsedText}" />
                                        <TextBlock Grid.Column="6" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding TyreWearDeltaText}" />
                                        <TextBlock Grid.Column="7" Foreground="{StaticResource FgLabelBrush}" Text="{Binding ValidityText}" />
                                        <TextBlock Grid.Column="8" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding TyreWindowText}" />
                                        <TextBlock Grid.Column="9" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding PitWindowText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="4" Padding="20" CornerRadius="20" Background="{StaticResource BgPanelBrush}">
                <StackPanel>
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               Text="对手列表" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource FgSectionBrush}"
                               Text="车手、位置、轮胎、胎龄、pit 状态、与我差距" />

                    <ListView Margin="0,18,0,0"
                              Background="{StaticResource TransparentBrush}"
                              BorderThickness="0"
                              ItemsSource="{Binding OpponentCars}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,10"
                                        Padding="14"
                                        CornerRadius="14"
                                        Background="{StaticResource BgCardBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="52" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="64" />
                                            <ColumnDefinition Width="72" />
                                            <ColumnDefinition Width="86" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding DisplayName}" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding PositionText}" />
                                        <TextBlock Grid.Column="2" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding TyreText}" />
                                        <TextBlock Grid.Column="3" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding TyreAgeText}" />
                                        <TextBlock Grid.Column="4" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding PitStatusText}" />
                                        <TextBlock Grid.Column="5" Foreground="{StaticResource FgLabelBrush}" Text="{Binding GapToPlayerText}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
    </Grid>

            <Grid Grid.Row="1" Margin="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="18" CornerRadius="20" Background="{StaticResource BgPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               Text="事件日志" />
                    <ListView Grid.Row="1"
                              Margin="0,16,0,0"
                              Background="{StaticResource TransparentBrush}"
                              BorderThickness="0"
                              ItemsSource="{Binding EventLogs}">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="{StaticResource BgCardBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="54" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="{Binding Timestamp}" />
                                        <TextBlock Grid.Column="1" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding Category}" />
                                        <TextBlock Grid.Column="2" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding Message}" TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="18" CornerRadius="20" Background="{StaticResource BgPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Padding="14"
                                CornerRadius="14"
                                Background="{StaticResource BgCardBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="90" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="AI 开关" />
                                <CheckBox Grid.Column="1"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding AiEnabled}" />

                                <TextBlock Grid.Row="1"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource FgLabelBrush}"
                                           Text="Base URL" />
                                <TextBox Grid.Row="1"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,12,0,0"
                                         Padding="8,5"
                                         Text="{Binding AiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="2"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource FgLabelBrush}"
                                           Text="Model" />
                                <TextBox Grid.Row="2"
                                         Grid.Column="1"
                                         Grid.ColumnSpan="2"
                                         Margin="0,12,0,0"
                                         Padding="8,5"
                                         Text="{Binding AiModel, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Grid.Row="3"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource FgLabelBrush}"
                                           Text="API Key" />
                                <PasswordBox Grid.Row="3"
                                             Grid.Column="1"
                                             Margin="0,12,8,0"
                                             Padding="8,5"
                                             attached:PasswordBoxBinding.BoundPassword="{Binding AiApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <StackPanel Grid.Row="3"
                                            Grid.Column="2"
                                            Margin="0,12,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock Foreground="{StaticResource FgSectionBrush}"
                                               Text="{Binding AiApiKeyStatusText}" />
                                    <TextBlock Margin="0,3,0,0"
                                               Foreground="{StaticResource FgLabelBrush}"
                                               Text="{Binding AiSettingsSaveStatusText}"
                                               TextWrapping="Wrap" />
                                </StackPanel>

                                <TextBlock Grid.Row="4"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource FgLabelBrush}"
                                           Text="TTS 开关" />
                                <CheckBox Grid.Row="4"
                                          Grid.Column="1"
                                          Margin="0,12,0,0"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding TtsEnabled}" />

                                <TextBlock Grid.Row="5"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource FgLabelBrush}"
                                           Text="Voice" />
                                <ComboBox Grid.Row="5"
                                          Grid.Column="1"
                                          Margin="0,12,8,0"
                                          Padding="8,5"
                                          IsEnabled="{Binding HasAvailableVoices}"
                                          ItemsSource="{Binding AvailableVoices}"
                                          SelectedItem="{Binding TtsVoiceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Grid.Row="5"
                                           Grid.Column="2"
                                           Margin="0,12,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource FgSectionBrush}"
                                           Text="{Binding TtsVoiceStatusText}"
                                           TextWrapping="Wrap" />

                                <TextBlock Grid.Row="6"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource FgLabelBrush}"
                                           Text="Volume" />
                                <Slider Grid.Row="6"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,12,0,0"
                                        Minimum="0"
                                        Maximum="100"
                                        TickFrequency="5"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding TtsVolume}" />

                                <TextBlock Grid.Row="7"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource FgLabelBrush}"
                                           Text="Rate" />
                                <Slider Grid.Row="7"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Margin="0,12,0,0"
                                        Minimum="-10"
                                        Maximum="10"
                                        TickFrequency="1"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding TtsRate}" />

                                <TextBlock Grid.Row="8"
                                           Margin="0,12,0,0"
                                           Foreground="{StaticResource FgLabelBrush}"
                                           Text="当前版本" />
                                <TextBlock Grid.Row="8"
                                           Grid.Column="1"
                                           Grid.ColumnSpan="2"
                                           Margin="0,12,0,0"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource FgSecondaryBrush}"
                                           Text="{Binding ApplicationVersionText}" />

                                <Button Grid.Row="9"
                                        Grid.Column="1"
                                        Grid.ColumnSpan="2"
                                        Width="132"
                                        Height="34"
                                        Margin="0,12,0,0"
                                        HorizontalAlignment="Left"
                                        Command="{Binding DownloadLatestVersionCommand}"
                                        Content="下载最新版本" />
                            </Grid>
                        </Border>

                        <Grid Grid.Row="1"
                              Margin="0,16,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FgPrimaryBrush}"
                                       Text="AI / TTS 日志" />
                            <ListView Grid.Row="1"
                                      Margin="0,16,0,0"
                              Background="{StaticResource TransparentBrush}"
                              BorderThickness="0"
                              ItemsSource="{Binding AiTtsLogs}">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,0,0,8"
                                                Padding="12"
                                                CornerRadius="12"
                                                Background="{StaticResource BgCardBrush}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="70" />
                                                    <ColumnDefinition Width="54" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="{Binding Timestamp}" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding Category}" />
                                                <TextBlock Grid.Column="2" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding Message}" TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
    </Grid>
    </Grid>
</UserControl>
