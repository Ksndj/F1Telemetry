                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="CornerAnalysisEngineerAdvicePanel"
                            Grid.Row="2"
                            Grid.Column="2"
