<UserControl x:Class="F1Telemetry.App.Views.CornerAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180"
             SizeChanged="CornerAnalysisView_SizeChanged">
    <UserControl.Resources>
        <Style x:Key="PanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="20" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="#0B1728" />
            <Setter Property="BorderBrush" Value="#1A3554" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="CardStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#10223A" />
            <Setter Property="BorderBrush" Value="#24476E" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#AFC2DA" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="MetricLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#7F95B2" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="MetricValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#F8FAFC" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="HeaderLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#93A9C8" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="CornerComboBoxStyle" TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Foreground" Value="#0F172A" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2563EB" />
            <Setter Property="BorderBrush" Value="#60A5FA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="9"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1D4ED8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#1E40AF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CornerListItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="#0F2036" />
            <Setter Property="BorderBrush" Value="#1E3A5C" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="RowRoot"
                                MinHeight="44"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowRoot" Property="Background" Value="#123050" />
                                <Setter TargetName="RowRoot" Property="BorderBrush" Value="#2B5C91" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowRoot" Property="Background" Value="#0F3A68" />
                                <Setter TargetName="RowRoot" Property="BorderBrush" Value="#3B82F6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="CornerAnalysisPageScrollViewer"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
    <Border Padding="20"
            Background="#06101C">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="12" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="CornerAnalysisHeader"
                    Style="{StaticResource PanelStyle}"
                    Padding="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   Foreground="#F8FAFC"
                                   Text="弯角分析" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding CornerAnalysis.StatusText}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right">
                        <TextBlock HorizontalAlignment="Right"
                                   Foreground="#93A9C8"
                                   Text="{Binding CornerAnalysis.AnalysisTimeText, StringFormat=分析时间：{0}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <WrapPanel x:Name="CornerAnalysisSummaryWrapPanel"
                       Grid.Row="2">
                <Border Style="{StaticResource CardStyle}"
                        MinWidth="220"
                        MaxWidth="300"
                        Margin="0,0,12,12"
                        MinHeight="86"
                        Padding="12"
                        BorderBrush="#1D64A8">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="正损失合计" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="21"
                                   FontWeight="SemiBold"
                                   Foreground="#F8FAFC"
                                   Text="{Binding CornerAnalysis.TotalTimeLossText}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#AFC2DA"
                                   Text="{Binding CornerAnalysis.NetTimeDeltaText, StringFormat=净时间差：{0}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}"
                        MinWidth="220"
                        MaxWidth="300"
                        Margin="0,0,12,12"
                        MinHeight="86"
                        Padding="12"
                        Background="#171532"
                        BorderBrush="#4C3B7C">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="最弱弯角" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#F8FAFC"
                                   Text="{Binding CornerAnalysis.WeakestCornerText}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}"
                        MinWidth="220"
                        MaxWidth="300"
                        Margin="0,0,12,12"
                        MinHeight="86"
                        Padding="12"
                        Background="#0D2A24"
                        BorderBrush="#2E7D5B">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="最高置信结果" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#F8FAFC"
                                   Text="{Binding CornerAnalysis.BestConfidenceCornerText}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#7DDFA4"
                                   Text="按置信度排序" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}"
                        MinWidth="220"
                        MaxWidth="300"
                        Margin="0,0,12,12"
                        MinHeight="86"
                        Padding="12"
                        Background="#2A2410"
                        BorderBrush="#826B25">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="参考图状态" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="#F8FAFC"
                                   Text="{Binding CornerAnalysis.DataQualityText}" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#F6C453"
                                   Text="数据可靠性" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="#AFC2DA"
                                   Text="{Binding CornerAnalysis.DataQualityReasonText}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding CornerAnalysis.DataQualityReasonText}" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border x:Name="CornerAnalysisFilterBar"
                    Grid.Row="4"
                    Style="{StaticResource PanelStyle}"
                    Padding="14">
                <WrapPanel x:Name="CornerAnalysisFilterWrapPanel">
                    <StackPanel MinWidth="220"
                                MaxWidth="360"
                                Margin="0,0,12,12">
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="赛段 / 样本" />
                        <ComboBox Margin="0,6,0,0"
                                  MaxWidth="360"
                                  Style="{StaticResource CornerComboBoxStyle}"
                                  DisplayMemberPath="SummaryText"
                                  ItemsSource="{Binding CornerAnalysis.HistoryBrowser.HistorySessions}"
                                  SelectedItem="{Binding CornerAnalysis.HistoryBrowser.SelectedSession, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel MinWidth="128"
                                MaxWidth="180"
                                Margin="0,0,12,12">
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="圈数" />
                        <ComboBox Margin="0,6,0,0"
                                  MaxWidth="180"
                                  Style="{StaticResource CornerComboBoxStyle}"
                                  DisplayMemberPath="LapText"
                                  ItemsSource="{Binding CornerAnalysis.HistoryBrowser.HistoryLaps}"
                                  SelectedItem="{Binding CornerAnalysis.SelectedLap, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel MinWidth="160"
                                MaxWidth="220"
                                Margin="0,0,12,12">
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="对比对象" />
                        <ComboBox Margin="0,6,0,0"
                                  MaxWidth="220"
                                  Style="{StaticResource CornerComboBoxStyle}"
                                  DisplayMemberPath="LapText"
                                  IsEditable="True"
                                  IsReadOnly="True"
                                  IsTextSearchEnabled="False"
                                  IsEnabled="{Binding CornerAnalysis.HasReferenceLapChoices}"
                                  Text="{Binding CornerAnalysis.ReferencePickerText, Mode=OneWay}"
                                  ToolTip="参考圈"
                                  ItemsSource="{Binding CornerAnalysis.HistoryBrowser.HistoryLaps}"
                                  SelectedItem="{Binding CornerAnalysis.SelectedReferenceLap, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel MinWidth="220"
                                MaxWidth="360"
                                Margin="0,0,12,12">
                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="当前选择" />
                        <Border Margin="0,6,0,0"
                                MinHeight="36"
                                Padding="10,8"
                                CornerRadius="8"
                                Background="#0D1B2F"
                                BorderBrush="#254568"
                                BorderThickness="1">
                            <TextBlock Foreground="#D7E4F3"
                                       Text="{Binding CornerAnalysis.SelectionText}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </StackPanel>

                    <WrapPanel VerticalAlignment="Bottom">
                        <Button MinWidth="96"
                                MaxWidth="128"
                                Height="36"
                                Margin="0,0,10,12"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CornerAnalysis.GenerateEngineerAdviceCommand}"
                                Content="{Binding CornerAnalysis.EngineerAdviceButtonText}" />
                        <Button MinWidth="96"
                                MaxWidth="128"
                                Height="36"
                                Margin="0,0,0,12"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CornerAnalysis.RefreshCommand}"
                                Content="刷新分析" />
                    </WrapPanel>
                </WrapPanel>
            </Border>

            <Grid x:Name="CornerAnalysisMainGrid"
                  Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="CornerAnalysisListColumn" Width="5*" />
                    <ColumnDefinition x:Name="CornerAnalysisMainGapColumn" Width="14" />
                    <ColumnDefinition x:Name="CornerAnalysisDetailsColumn" Width="4*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="CornerAnalysisMainGapRow" Height="0" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="CornerAnalysisListPanel"
                        Grid.Row="0"
                        Grid.Column="0"
                        MinHeight="220"
                        MaxHeight="520"
                        VerticalAlignment="Top"
                        Style="{StaticResource PanelStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="10" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#F8FAFC"
                                       Text="弯角列表" />
                            <TextBlock HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="#AFC2DA"
                                       Text="{Binding CornerAnalysis.EmptyStateText}" />
                        </Grid>

                        <ScrollViewer x:Name="CornerAnalysisTableScrollViewer"
                                      Grid.Row="2"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Grid.IsSharedSizeScope="True">
                                <Border Padding="12,8"
                                        CornerRadius="8"
                                        Background="#13243B"
                                        BorderBrush="#213A5F"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44" SharedSizeGroup="CornerNumberColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="112" SharedSizeGroup="CornerNameColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="CornerMinimumColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="146" SharedSizeGroup="CornerSpeedColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="72" SharedSizeGroup="CornerBrakeColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="86" SharedSizeGroup="CornerDeltaColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="70" SharedSizeGroup="CornerConfidenceColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="104" SharedSizeGroup="CornerWarningColumn" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource HeaderLabelStyle}" Text="弯角" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource HeaderLabelStyle}" Text="名称" />
                                        <TextBlock Grid.Column="2" Style="{StaticResource HeaderLabelStyle}" Text="最低" />
                                        <TextBlock Grid.Column="3" Style="{StaticResource HeaderLabelStyle}" Text="入 / 弯 / 出" />
                                        <TextBlock Grid.Column="4" Style="{StaticResource HeaderLabelStyle}" Text="刹车" />
                                        <TextBlock Grid.Column="5"
                                                   Style="{StaticResource HeaderLabelStyle}"
                                                   Text="时间差"
                                                   ToolTip="正数为比参考圈慢，负数为比参考圈快。" />
                                        <TextBlock Grid.Column="6" Style="{StaticResource HeaderLabelStyle}" Text="置信" />
                                        <TextBlock Grid.Column="7" Style="{StaticResource HeaderLabelStyle}" Text="数据限制" />
                                    </Grid>
                                </Border>

                                <ListBox Margin="0,8,0,0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource CornerListItemStyle}"
                                         ItemsSource="{Binding CornerAnalysis.CornerRows}"
                                         SelectedItem="{Binding CornerAnalysis.SelectedCorner, Mode=TwoWay}"
                                         HorizontalContentAlignment="Left"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid MinHeight="44">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44" SharedSizeGroup="CornerNumberColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="112" SharedSizeGroup="CornerNameColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="80" SharedSizeGroup="CornerMinimumColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="146" SharedSizeGroup="CornerSpeedColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="72" SharedSizeGroup="CornerBrakeColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="86" SharedSizeGroup="CornerDeltaColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="70" SharedSizeGroup="CornerConfidenceColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="104" SharedSizeGroup="CornerWarningColumn" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="3"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="8,0,0,8"
                                                        Background="{Binding RowAccentBrush}" />

                                                <TextBlock Margin="16,0,8,0"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="#C7D9F0"
                                                           Text="{Binding CornerNumberText}" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="#F8FAFC"
                                                           Text="{Binding CornerNameText}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           Foreground="#D7E4F3"
                                                           Text="{Binding MinimumSpeedText}" />
                                                <TextBlock Grid.Column="3"
                                                           VerticalAlignment="Center"
                                                           Foreground="#D7E4F3"
                                                           Text="{Binding SpeedWindowText}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="4"
                                                           VerticalAlignment="Center"
                                                           Foreground="#D7E4F3"
                                                           Text="{Binding BrakeText}" />
                                                <TextBlock Grid.Column="5"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding TimeLossBrush}"
                                                           Text="{Binding TimeLossText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding TimeDifferenceTooltipText}" />
                                                <Border Grid.Column="6"
                                                        Width="52"
                                                        Height="24"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="7"
                                                        Background="#103760">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding ConfidenceBrush}"
                                                               Text="{Binding ConfidenceText}" />
                                                </Border>
                                                <TextBlock Grid.Column="7"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding WarningBrush}"
                                                           Text="{Binding CompactWarningText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding WarningTooltipText}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>

                        <TextBlock Grid.Row="3"
                                   Margin="0,10,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding CornerAnalysis.CornerRows.Count, StringFormat=共 {0} 个弯角}" />
                    </Grid>
                </Border>

                <Grid x:Name="CornerAnalysisRightDetails"
                      Grid.Row="0"
                      Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="CornerAnalysisDetailColumn" Width="*" />
                        <ColumnDefinition x:Name="CornerAnalysisRightGapColumn" Width="10" />
                        <ColumnDefinition x:Name="CornerAnalysisTrackColumn" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border x:Name="CornerAnalysisDetailPanel"
                            Style="{StaticResource PanelStyle}">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#F8FAFC"
                                       Text="{Binding CornerAnalysis.SelectedCorner.CornerText, StringFormat=弯角详情（{0}）}" />
                            <ItemsControl Margin="0,12,0,0"
                                          ItemsSource="{Binding CornerAnalysis.SelectedCorner.DetailMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border MinHeight="74"
                                                Margin="0,0,8,8"
                                                Padding="10"
                                                CornerRadius="9"
                                                Background="#10233A"
                                                BorderBrush="#24476E"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="6" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="6" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource MetricLabelStyle}"
                                                           Text="{Binding Title}" />
                                                <TextBlock Grid.Column="1"
                                                           Foreground="{Binding DifferenceBrush}"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding DifferenceText}" />
                                                <TextBlock Grid.Row="2"
                                                           Foreground="#F8FAFC"
                                                           FontSize="16"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CurrentText}" />
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="1"
                                                           Foreground="#93A9C8"
                                                           Text="{Binding ReferenceText}" />
                                                <Grid Grid.Row="4"
                                                      Grid.ColumnSpan="2"
                                                      Height="5"
                                                      Background="#0A1626">
                                                    <Border Width="{Binding DifferenceBarWidth}"
                                                            HorizontalAlignment="Left"
                                                            CornerRadius="3"
                                                            Background="{Binding DifferenceBrush}" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource CardStyle}" Padding="10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="时间差" />
                                        <TextBlock Margin="0,5,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding CornerAnalysis.SelectedCorner.TimeLossBrush}"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.TimeLossText}"
                                                   ToolTip="{Binding CornerAnalysis.SelectedCorner.TimeDifferenceTooltipText}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource CardStyle}" Padding="10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="置信度" />
                                        <TextBlock Margin="0,5,0,0"
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding CornerAnalysis.SelectedCorner.ConfidenceBrush}"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.ConfidenceText}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="CornerAnalysisTrackMapPanel"
                            Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource PanelStyle}"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock FontSize="18"
                                           FontWeight="SemiBold"
                                           Foreground="#F8FAFC"
                                           Text="赛道位置" />
                                <TextBlock Grid.Column="1"
                                           Foreground="#93A9C8"
                                           Text="{Binding CornerAnalysis.SelectedCorner.TrackMapStatusText}" />
                            </Grid>
                            <Border Grid.Row="2"
                                    Style="{StaticResource CardStyle}"
                                    Padding="12">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Viewbox Height="170"
                                             Stretch="Uniform">
                                        <Viewbox.Style>
                                            <Style TargetType="{x:Type Viewbox}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasDrawableTrackMap}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Viewbox.Style>
                                        <Canvas Width="240"
                                                Height="170"
                                                ClipToBounds="True">
                                            <Rectangle Width="240"
                                                       Height="170"
                                                       RadiusX="12"
                                                       RadiusY="12"
                                                       Fill="#0B1628"
                                                       Stroke="#1D3B5C"
                                                       StrokeThickness="1" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.TrackMapPathData}"
                                                  Stroke="#6B7F99"
                                                  StrokeThickness="3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.TrackMapHighlightPathData}"
                                                  Stroke="#38BDF8"
                                                  StrokeThickness="5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                            <Ellipse Canvas.Left="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerLeft}"
                                                     Canvas.Top="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerTop}"
                                                     Width="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerSize}"
                                                     Height="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerSize}"
                                                     Fill="#FBBF24"
                                                     Stroke="#0B1628"
                                                     StrokeThickness="2" />
                                            <TextBlock Canvas.Left="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerX}"
                                                       Canvas.Top="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerY}"
                                                       Margin="8,-18,0,0"
                                                       Foreground="#F8FAFC"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CornerAnalysis.SelectedCorner.TrackMapCornerLabelText}" />
                                        </Canvas>
                                    </Viewbox>
                                    <Border MinHeight="170"
                                            CornerRadius="10"
                                            Background="#0B1628"
                                            BorderBrush="#1D3B5C"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasDrawableTrackMap}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Margin="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="#D7E4F3"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.TrackMapEmptyStateText}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                    <TextBlock Grid.Row="2"
                                               Foreground="#D7E4F3"
                                               FontWeight="SemiBold"
                                               Text="{Binding CornerAnalysis.SelectedCorner.TrackMapWarningText}"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding CornerAnalysis.SelectedCorner.TrackMapWarningText}" />
                                </Grid>
                            </Border>
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="#93A9C8"
                                           Text="{Binding CornerAnalysis.SelectedCorner.TrackMapSourceText}" />
                                <TextBlock Grid.Column="2"
                                           Foreground="#93A9C8"
                                           HorizontalAlignment="Right"
                                           Text="{Binding CornerAnalysis.SelectedCorner.TrackMapQualityText}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="CornerAnalysisVisualEvidencePanel"
                            Grid.Row="2"
                            Grid.ColumnSpan="3"
                            Style="{StaticResource PanelStyle}"
                            Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="96" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#F8FAFC"
                                       Text="视觉证据" />

                            <Border Grid.Row="2"
                                    Style="{StaticResource CardStyle}"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="速度对比" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="#93A9C8"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.SpeedChartStatusText}" />
                                    </Grid>
                                    <Viewbox Grid.Row="1"
                                             Margin="0,6,0,0"
                                             Height="54"
                                             Stretch="Fill">
                                        <Viewbox.Style>
                                            <Style TargetType="{x:Type Viewbox}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasSpeedChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Viewbox.Style>
                                        <Canvas Width="220" Height="72">
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.SpeedReferencePathData}"
                                                  Stroke="#64748B"
                                                  StrokeDashArray="4 3"
                                                  StrokeThickness="2" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.SpeedCurrentPathData}"
                                                  Stroke="#38BDF8"
                                                  StrokeThickness="2.5" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#AFC2DA"
                                               FontWeight="SemiBold"
                                               Text="{Binding CornerAnalysis.SelectedCorner.SpeedChartStatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasSpeedChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.Column="2"
                                    Style="{StaticResource CardStyle}"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="刹车对比" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="#93A9C8"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.BrakeChartStatusText}" />
                                    </Grid>
                                    <Viewbox Grid.Row="1"
                                             Margin="0,6,0,0"
                                             Height="54"
                                             Stretch="Fill">
                                        <Viewbox.Style>
                                            <Style TargetType="{x:Type Viewbox}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasBrakeChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Viewbox.Style>
                                        <Canvas Width="220" Height="72">
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.BrakeReferencePathData}"
                                                  Stroke="#64748B"
                                                  StrokeDashArray="4 3"
                                                  StrokeThickness="2" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.BrakeCurrentPathData}"
                                                  Stroke="#F87171"
                                                  StrokeThickness="2.5" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#AFC2DA"
                                               FontWeight="SemiBold"
                                               Text="{Binding CornerAnalysis.SelectedCorner.BrakeChartStatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasBrakeChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.Column="4"
                                    Style="{StaticResource CardStyle}"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource MetricLabelStyle}" Text="油门对比" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="#93A9C8"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.ThrottleChartStatusText}" />
                                    </Grid>
                                    <Viewbox Grid.Row="1"
                                             Margin="0,6,0,0"
                                             Height="54"
                                             Stretch="Fill">
                                        <Viewbox.Style>
                                            <Style TargetType="{x:Type Viewbox}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasThrottleChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Viewbox.Style>
                                        <Canvas Width="220" Height="72">
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.ThrottleReferencePathData}"
                                                  Stroke="#64748B"
                                                  StrokeDashArray="4 3"
                                                  StrokeThickness="2" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.ThrottleCurrentPathData}"
                                                  Stroke="#34D399"
                                                  StrokeThickness="2.5" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#AFC2DA"
                                               FontWeight="SemiBold"
                                               Text="{Binding CornerAnalysis.SelectedCorner.ThrottleChartStatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasThrottleChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <Border x:Name="CornerAnalysisEngineerAdvicePanel"
                            Grid.Row="4"
                            Grid.ColumnSpan="3"
                            Style="{StaticResource PanelStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Foreground="#F8FAFC"
                                       Text="工程师建议" />
                            <ScrollViewer Grid.Row="2"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Margin="0,0,0,8"
                                               Foreground="#FBBF24"
                                               Text="{Binding CornerAnalysis.EngineerAdviceNoticeText}"
                                               TextWrapping="Wrap" />
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="#171532"
                                            BorderBrush="#4C3B7C"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="主要问题" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#F8FAFC"
                                                       FontWeight="SemiBold"
                                                       MaxHeight="42"
                                                       Text="{Binding CornerAnalysis.EngineerPrimaryProblemText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="#0B2431"
                                            BorderBrush="#1D5C78"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="驾驶动作" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#D7E4F3"
                                                       FontWeight="SemiBold"
                                                       MaxHeight="42"
                                                       Text="{Binding CornerAnalysis.EngineerDrivingActionText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,0,8"
                                            Padding="12"
                                            CornerRadius="10"
                                            Background="#0D2A24"
                                            BorderBrush="#2E7D5B"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelStyle}" Text="下圈重点" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Foreground="#D7E4F3"
                                                       FontWeight="SemiBold"
                                                       MaxHeight="42"
                                                       Text="{Binding CornerAnalysis.EngineerNextLapFocusText}"
                                                       TextTrimming="CharacterEllipsis"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <TextBlock Margin="0,4,0,0"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="{Binding CornerAnalysis.EngineerAdviceStatusText}" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border x:Name="CornerAnalysisNotesPanel"
                    Grid.Row="8"
                    Style="{StaticResource PanelStyle}"
                    Padding="18">
                <WrapPanel x:Name="CornerAnalysisNotesWrapPanel">
                    <StackPanel MinWidth="320"
                                MaxWidth="560"
                                Margin="0,0,24,12">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#AFC2DA"
                                   Text="数据质量提示" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding CornerAnalysis.DataQualityReasonText}" />
                    </StackPanel>
                    <StackPanel MinWidth="320"
                                MaxWidth="560"
                                Margin="0,0,0,12">
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#7DD3FC"
                                   Text="AI 分析备注" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding CornerAnalysis.AiAnnotationText}" />
                    </StackPanel>
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
    </ScrollViewer>
</UserControl>
