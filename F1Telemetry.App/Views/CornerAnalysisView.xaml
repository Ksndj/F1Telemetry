                                                   Foreground="{StaticResource FgSectionBrush}"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.ThrottleChartStatusText}" />
                                    </Grid>
                                    <Viewbox Grid.Row="1"
                                             Margin="0,4,0,0"
                                             Height="38"
                                             Stretch="Fill">
