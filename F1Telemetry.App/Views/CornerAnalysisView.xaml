                                       FontSize="16"
                                       Text="工程师建议" />
                            <StackPanel Grid.Row="2">
                                <TextBlock Margin="0,0,0,6"
                                           Foreground="{StaticResource TrackMapMarkerBrush}"
                                           Text="{Binding CornerAnalysis.EngineerAdviceNoticeText}"
                                           TextWrapping="Wrap" />
                                <StackPanel x:Name="CornerAnalysisEngineerAdviceCardsPanel">
                                    <Border Margin="0,0,0,6"
                                            HorizontalAlignment="Stretch"
                                            Padding="8"
                                            CornerRadius="10"
                                            Background="{StaticResource StatusProblemBgBrush}"
                                            BorderBrush="{StaticResource StatusProblemBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="主要问题" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource FgPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CornerAnalysis.EngineerPrimaryProblemText}"
                                                       TextTrimming="None"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0,0,0,6"
                                            HorizontalAlignment="Stretch"
                                            Padding="8"
                                            CornerRadius="10"
                                            Background="{StaticResource BgInfoCardBrush}"
                                            BorderBrush="{StaticResource StatusInfoBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="驾驶动作" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource FgSecondaryBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CornerAnalysis.EngineerDrivingActionText}"
                                                       TextTrimming="None"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                    <Border Margin="0"
                                            HorizontalAlignment="Stretch"
                                            Padding="8"
                                            CornerRadius="10"
                                            Background="{StaticResource StatusPositiveBgBrush}"
                                            BorderBrush="{StaticResource StatusPositiveBorderBrush}"
                                            BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="下圈重点" />
                                            <TextBlock Margin="0,4,0,0"
                                                       Foreground="{StaticResource FgSecondaryBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CornerAnalysis.EngineerNextLapFocusText}"
                                                       TextTrimming="None"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                <TextBlock Margin="0,6,0,0"
                                           Style="{StaticResource MutedTextStyle}"
                                           Text="{Binding CornerAnalysis.EngineerAdviceStatusText}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <Border x:Name="CornerAnalysisNotesPanel"
                    Grid.Row="8"
                    Style="{StaticResource GlassCardStyle}"
                    Padding="12">
                <WrapPanel x:Name="CornerAnalysisNotesWrapPanel">
                    <StackPanel MinWidth="280"
                                MaxWidth="560"
                                Margin="0,0,18,8">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   FontSize="15"
                                   Text="数据质量提示" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding CornerAnalysis.DataQualityReasonText}" />
                    </StackPanel>
                    <StackPanel MinWidth="280"
                                MaxWidth="560"
                                Margin="0,0,0,8">
                        <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                   FontSize="15"
                                   Text="AI 分析备注" />
                        <TextBlock Margin="0,4,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding CornerAnalysis.AiAnnotationText}" />
                    </StackPanel>
                </WrapPanel>
            </Border>
        </Grid>
    </Border>
    </ScrollViewer>
</UserControl>
