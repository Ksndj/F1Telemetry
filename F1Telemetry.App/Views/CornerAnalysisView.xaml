                                    <TextBlock Grid.Row="1"
                                               Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource FgSectionBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding CornerAnalysis.SelectedCorner.BrakeChartStatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasBrakeChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.Column="4"
                                    Style="{StaticResource MetricTileStyle}"
                                    Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="油门对比" />
