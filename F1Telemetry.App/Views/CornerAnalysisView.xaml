<UserControl x:Class="F1Telemetry.App.Views.CornerAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:attached="clr-namespace:F1Telemetry.App.AttachedProperties"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180"
             attached:ResponsiveLayoutBehavior.Breakpoints="1000,1300">
    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="ResponsiveLayoutStates">
            <VisualState x:Name="Narrow">
                <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisListColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>1*</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisMainGapColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>0</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisDetailsColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>0</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisMainGapRow" Storyboard.TargetProperty="Height">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>12</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisListPanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisListPanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisListPanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisRightDetails" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="2" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisRightDetails" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisRightDetails" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisDetailColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>1*</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisRightGapColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>0</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>0</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisDetailPanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisDetailPanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisDetailPanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="2" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="4" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="6" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                </Storyboard>
            </VisualState>
            <VisualState x:Name="Medium">
                <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisListColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>1*</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisMainGapColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>12</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisDetailsColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>1*</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisMainGapRow" Storyboard.TargetProperty="Height">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>0</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisRightGapColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>0</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>0</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="2" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="4" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="6" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="3" />
                    </Int32AnimationUsingKeyFrames>
                </Storyboard>
            </VisualState>
            <VisualState x:Name="Wide">
                <Storyboard>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisListColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>2*</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisMainGapColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>10</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisDetailsColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>3*</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisMainGapRow" Storyboard.TargetProperty="Height">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>0</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisRightGapColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>10</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <ObjectAnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackColumn" Storyboard.TargetProperty="Width">
                        <DiscreteObjectKeyFrame KeyTime="0">
                            <DiscreteObjectKeyFrame.Value>
                                <GridLength>1*</GridLength>
                            </DiscreteObjectKeyFrame.Value>
                        </DiscreteObjectKeyFrame>
                    </ObjectAnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="2" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisTrackMapPanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="1" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="2" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="0" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisVisualEvidencePanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="1" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.Row)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="2" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.Column)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="2" />
                    </Int32AnimationUsingKeyFrames>
                    <Int32AnimationUsingKeyFrames Storyboard.TargetName="CornerAnalysisEngineerAdvicePanel" Storyboard.TargetProperty="(Grid.ColumnSpan)">
                        <DiscreteInt32KeyFrame KeyTime="0" Value="1" />
                    </Int32AnimationUsingKeyFrames>
                </Storyboard>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    <UserControl.Resources>
        <Style x:Key="CornerAnalysisReferencePickerComboBoxStyle"
               TargetType="{x:Type ComboBox}">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Foreground" Value="{StaticResource FgPrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource BgInputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderComboBoxBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="MaxDropDownHeight" Value="240" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}" />
        </Style>

        <Style x:Key="CornerListItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource BgListItemBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderPanelBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ListBoxItem}">
                        <Border x:Name="RowRoot"
                                MinHeight="36"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RowRoot" Property="Background" Value="{StaticResource BgListItemHoverBrush}" />
                                <Setter TargetName="RowRoot" Property="BorderBrush" Value="{StaticResource BorderListItemHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="RowRoot" Property="Background" Value="{StaticResource BgListItemSelectedBrush}" />
                                <Setter TargetName="RowRoot" Property="BorderBrush" Value="{StaticResource BorderListItemSelectedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer x:Name="CornerAnalysisPageScrollViewer"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
    <Border Padding="14"
            Background="{StaticResource BgDeepBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="8" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="CornerAnalysisHeader"
                    Style="{StaticResource GlassCardStyle}"
                    Padding="14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Grid Style="{StaticResource SectionHeaderStyle}"
                          Margin="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource IconBadgeStyle}">
                            <TextBlock Style="{StaticResource IconTextStyle}" Text="&#xE7C1;" />
                        </Border>

                        <StackPanel Grid.Column="2">
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       FontSize="22"
                                       Text="弯角分析" />
                            <TextBlock Margin="0,4,0,0"
                                       Style="{StaticResource BodyTextStyle}"
                                       Text="{Binding CornerAnalysis.StatusText}" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right">
                        <TextBlock HorizontalAlignment="Right"
                                   Style="{StaticResource MetricLabelTextStyle}"
                                   Text="分析时间" />
                        <TextBlock Margin="0,4,0,0"
                                   HorizontalAlignment="Right"
                                   Style="{StaticResource BodyTextStyle}"
                                   Text="{Binding CornerAnalysis.AnalysisTimeText, StringFormat=分析时间：{0}}" />
                    </StackPanel>
                </Grid>
            </Border>

            <WrapPanel x:Name="CornerAnalysisSummaryWrapPanel"
                       Grid.Row="2">
                <Border Style="{StaticResource MetricTileStyle}"
                        MinWidth="205"
                        MaxWidth="280"
                        Margin="0,0,10,8"
                        MinHeight="68"
                        Padding="10"
                        BorderBrush="{StaticResource BorderMetricTileFocusBrush}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="正损失合计" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="{Binding CornerAnalysis.TotalTimeLossText}" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="{StaticResource FgSectionBrush}"
                                   Text="{Binding CornerAnalysis.NetTimeDeltaText, StringFormat=净时间差：{0}}" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricTileStyle}"
                        MinWidth="205"
                        MaxWidth="280"
                        Margin="0,0,10,8"
                        MinHeight="68"
                        Padding="10"
                        Background="{StaticResource StatusProblemBgBrush}"
                        BorderBrush="{StaticResource StatusProblemBorderBrush}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="最弱弯角" />
                        <TextBlock Margin="0,5,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="{Binding CornerAnalysis.WeakestCornerText}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricTileStyle}"
                        MinWidth="205"
                        MaxWidth="280"
                        Margin="0,0,10,8"
                        MinHeight="68"
                        Padding="10"
                        Background="{StaticResource StatusPositiveBgBrush}"
                        BorderBrush="{StaticResource StatusPositiveBorderBrush}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="最高置信结果" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="{Binding CornerAnalysis.BestConfidenceCornerText}"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="{StaticResource StatusPositiveFgBrush}"
                                   Text="按置信度排序" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource MetricTileStyle}"
                        MinWidth="205"
                        MaxWidth="280"
                        Margin="0,0,10,8"
                        MinHeight="68"
                        Padding="10"
                        Background="{StaticResource StatusWarningBgBrush}"
                        BorderBrush="{StaticResource StatusWarningBorderBrush}">
                    <StackPanel>
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="参考图状态" />
                        <TextBlock Margin="0,3,0,0"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="{Binding CornerAnalysis.DataQualityText}" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="{StaticResource StatusWarningFgBrush}"
                                   Text="数据可靠性" />
                        <TextBlock Margin="0,2,0,0"
                                   Foreground="{StaticResource FgSectionBrush}"
                                   Text="{Binding CornerAnalysis.DataQualityReasonText}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding CornerAnalysis.DataQualityReasonText}" />
                    </StackPanel>
                </Border>
            </WrapPanel>

            <Border x:Name="CornerAnalysisFilterBar"
                    Grid.Row="4"
                    Style="{StaticResource GlassCardStyle}"
                    Padding="10">
                <WrapPanel x:Name="CornerAnalysisFilterWrapPanel">
                    <StackPanel MinWidth="220"
                                MaxWidth="360"
                                Margin="0,0,10,8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="赛段 / 样本" />
                        <ComboBox Margin="0,6,0,0"
                                  MaxWidth="360"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  DisplayMemberPath="SummaryText"
                                  ItemsSource="{Binding CornerAnalysis.HistoryBrowser.HistorySessions}"
                                  SelectedItem="{Binding CornerAnalysis.HistoryBrowser.SelectedSession, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel MinWidth="128"
                                MaxWidth="180"
                                Margin="0,0,10,8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="圈数" />
                        <ComboBox Margin="0,6,0,0"
                                  MaxWidth="180"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  DisplayMemberPath="LapText"
                                  ItemsSource="{Binding CornerAnalysis.HistoryBrowser.HistoryLaps}"
                                  SelectedItem="{Binding CornerAnalysis.SelectedLap, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel MinWidth="160"
                                MaxWidth="220"
                                Margin="0,0,10,8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="对比对象" />
                        <ComboBox Margin="0,6,0,0"
                                  MaxWidth="220"
                                  Style="{StaticResource CornerAnalysisReferencePickerComboBoxStyle}"
                                  DisplayMemberPath="LapText"
                                  IsEditable="True"
                                  IsReadOnly="True"
                                  IsTextSearchEnabled="False"
                                  IsEnabled="{Binding CornerAnalysis.HasReferenceLapChoices}"
                                  Text="{Binding CornerAnalysis.ReferencePickerText, Mode=OneWay}"
                                  ToolTip="参考圈"
                                  ItemsSource="{Binding CornerAnalysis.HistoryBrowser.HistoryLaps}"
                                  SelectedItem="{Binding CornerAnalysis.SelectedReferenceLap, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel MinWidth="220"
                                MaxWidth="360"
                                Margin="0,0,10,8">
                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="当前选择" />
                        <Border Margin="0,6,0,0"
                                MinHeight="32"
                                Style="{StaticResource PillTagStyle}">
                            <TextBlock Foreground="{StaticResource FgSecondaryBrush}"
                                       Text="{Binding CornerAnalysis.SelectionText}"
                                       TextTrimming="CharacterEllipsis" />
                        </Border>
                    </StackPanel>

                    <WrapPanel VerticalAlignment="Bottom">
                        <Button MinWidth="96"
                                MaxWidth="128"
                                Height="32"
                                Margin="0,0,10,8"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding CornerAnalysis.GenerateEngineerAdviceCommand}"
                                Content="{Binding CornerAnalysis.EngineerAdviceButtonText}" />
                        <Button MinWidth="96"
                                MaxWidth="128"
                                Height="32"
                                Margin="0,0,0,8"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding CornerAnalysis.RefreshCommand}"
                                Content="刷新分析" />
                    </WrapPanel>
                </WrapPanel>
            </Border>

            <Grid x:Name="CornerAnalysisMainGrid"
                  Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition x:Name="CornerAnalysisListColumn" Width="2*" />
                    <ColumnDefinition x:Name="CornerAnalysisMainGapColumn" Width="10" />
                    <ColumnDefinition x:Name="CornerAnalysisDetailsColumn" Width="3*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition x:Name="CornerAnalysisMainGapRow" Height="0" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border x:Name="CornerAnalysisListPanel"
                        Grid.Row="0"
                        Grid.Column="0"
                        MaxHeight="360"
                        VerticalAlignment="Top"
                        Style="{StaticResource GlassCardStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="8" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       FontSize="16"
                                       Text="弯角列表" />
                            <TextBlock HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource FgSectionBrush}"
                                       Text="{Binding CornerAnalysis.EmptyStateText}" />
                        </Grid>

                        <ScrollViewer x:Name="CornerAnalysisTableScrollViewer"
                                      Grid.Row="2"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Grid.IsSharedSizeScope="True">
                                <Border Padding="12,8"
                                        CornerRadius="8"
                                        Background="{StaticResource BgTableHeaderBrush}"
                                        BorderBrush="{StaticResource BorderTableHeaderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" SharedSizeGroup="CornerNumberColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="CornerNameColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="66" SharedSizeGroup="CornerMinimumColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="126" SharedSizeGroup="CornerSpeedColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="62" SharedSizeGroup="CornerBrakeColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="CornerDeltaColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="62" SharedSizeGroup="CornerConfidenceColumn" />
                                            <ColumnDefinition Width="Auto" MinWidth="90" SharedSizeGroup="CornerWarningColumn" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource HeaderLabelStyle}" Text="弯角" />
                                        <TextBlock Grid.Column="1" Style="{StaticResource HeaderLabelStyle}" Text="名称" />
                                        <TextBlock Grid.Column="2" Style="{StaticResource HeaderLabelStyle}" Text="最低" />
                                        <TextBlock Grid.Column="3" Style="{StaticResource HeaderLabelStyle}" Text="入 / 弯 / 出" />
                                        <TextBlock Grid.Column="4" Style="{StaticResource HeaderLabelStyle}" Text="刹车" />
                                        <TextBlock Grid.Column="5"
                                                   Style="{StaticResource HeaderLabelStyle}"
                                                   Text="时间差"
                                                   ToolTip="正数为比参考圈慢，负数为比参考圈快。" />
                                        <TextBlock Grid.Column="6" Style="{StaticResource HeaderLabelStyle}" Text="置信" />
                                        <TextBlock Grid.Column="7" Style="{StaticResource HeaderLabelStyle}" Text="数据限制" />
                                    </Grid>
                                </Border>

                                <ListBox Margin="0,6,0,0"
                                         Background="{StaticResource TransparentBrush}"
                                         BorderThickness="0"
                                         ItemContainerStyle="{StaticResource CornerListItemStyle}"
                                         ItemsSource="{Binding CornerAnalysis.CornerRows}"
                                         SelectedItem="{Binding CornerAnalysis.SelectedCorner, Mode=TwoWay}"
                                         HorizontalContentAlignment="Left"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid MinHeight="36">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="40" SharedSizeGroup="CornerNumberColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="96" SharedSizeGroup="CornerNameColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="66" SharedSizeGroup="CornerMinimumColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="126" SharedSizeGroup="CornerSpeedColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="62" SharedSizeGroup="CornerBrakeColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="76" SharedSizeGroup="CornerDeltaColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="62" SharedSizeGroup="CornerConfidenceColumn" />
                                                    <ColumnDefinition Width="Auto" MinWidth="90" SharedSizeGroup="CornerWarningColumn" />
                                                </Grid.ColumnDefinitions>

                                                <Border Width="3"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="8,0,0,8"
                                                        Background="{Binding RowAccentBrush}" />

                                                <TextBlock Margin="16,0,8,0"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FgTableIndexBrush}"
                                                           Text="{Binding CornerNumberText}" />
                                                <TextBlock Grid.Column="1"
                                                           Margin="0,0,12,0"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FgPrimaryBrush}"
                                                           Text="{Binding CornerNameText}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="2"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource FgSecondaryBrush}"
                                                           Text="{Binding MinimumSpeedText}" />
                                                <TextBlock Grid.Column="3"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource FgSecondaryBrush}"
                                                           Text="{Binding SpeedWindowText}"
                                                           TextTrimming="CharacterEllipsis" />
                                                <TextBlock Grid.Column="4"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource FgSecondaryBrush}"
                                                           Text="{Binding BrakeText}" />
                                                <TextBlock Grid.Column="5"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding TimeLossBrush}"
                                                           Text="{Binding TimeLossText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding TimeDifferenceTooltipText}" />
                                                <Border Grid.Column="6"
                                                        Width="48"
                                                        Height="22"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        CornerRadius="7"
                                                        Background="{StaticResource BgInlineBadgeBrush}">
                                                    <TextBlock HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding ConfidenceBrush}"
                                                               Text="{Binding ConfidenceText}" />
                                                </Border>
                                                <TextBlock Grid.Column="7"
                                                           VerticalAlignment="Center"
                                                           Foreground="{Binding WarningBrush}"
                                                           Text="{Binding CompactWarningText}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding WarningTooltipText}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </ScrollViewer>

                        <TextBlock Grid.Row="3"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding CornerAnalysis.CornerRows.Count, StringFormat=共 {0} 个弯角}" />
                    </Grid>
                </Border>

                <Grid x:Name="CornerAnalysisRightDetails"
                      Grid.Row="0"
                      Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="CornerAnalysisDetailColumn" Width="*" />
                        <ColumnDefinition x:Name="CornerAnalysisRightGapColumn" Width="10" />
                        <ColumnDefinition x:Name="CornerAnalysisTrackColumn" Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Border x:Name="CornerAnalysisDetailPanel"
                        Style="{StaticResource GlassCardStyle}">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       FontSize="16"
                                       Text="{Binding CornerAnalysis.SelectedCorner.CornerText, StringFormat=弯角详情（{0}）}" />
                            <ItemsControl Margin="0,8,0,0"
                                          ItemsSource="{Binding CornerAnalysis.SelectedCorner.DetailMetrics}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border MinHeight="54"
                                                Margin="0,0,6,6"
                                                Padding="8"
                                                CornerRadius="9"
                                                Background="{StaticResource BgMetricTileBrush}"
                                                BorderBrush="{StaticResource BorderMetricTileFocusBrush}"
                                                BorderThickness="1">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="4" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="4" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Style="{StaticResource MetricLabelTextStyle}"
                                                           Text="{Binding Title}" />
                                                <TextBlock Grid.Column="1"
                                                           Foreground="{Binding DifferenceBrush}"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding DifferenceText}" />
                                                <TextBlock Grid.Row="2"
                                                           Foreground="{StaticResource FgPrimaryBrush}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Text="{Binding CurrentText}" />
                                                <TextBlock Grid.Row="2"
                                                           Grid.Column="1"
                                                           Foreground="{StaticResource FgSectionBrush}"
                                                           Text="{Binding ReferenceText}" />
                                                <Grid Grid.Row="4"
                                                      Grid.ColumnSpan="2"
                                                      Height="5"
                                                      Background="{StaticResource BgProgressTrackBrush}">
                                                    <Border Width="{Binding DifferenceBarWidth}"
                                                            HorizontalAlignment="Left"
                                                            CornerRadius="3"
                                                            Background="{Binding DifferenceBrush}" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Style="{StaticResource MetricTileStyle}" Padding="10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="时间差" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding CornerAnalysis.SelectedCorner.TimeLossBrush}"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.TimeLossText}"
                                                   ToolTip="{Binding CornerAnalysis.SelectedCorner.TimeDifferenceTooltipText}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource MetricTileStyle}" Padding="10">
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="置信度" />
                                        <TextBlock Margin="0,3,0,0"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding CornerAnalysis.SelectedCorner.ConfidenceBrush}"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.ConfidenceText}" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="CornerAnalysisTrackMapPanel"
                            Grid.Row="0"
                            Grid.Column="2"
                            Style="{StaticResource GlassCardStyle}"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                           FontSize="16"
                                           Text="赛道位置" />
                                <TextBlock Grid.Column="1"
                                           Foreground="{StaticResource FgSectionBrush}"
                                           Text="{Binding CornerAnalysis.SelectedCorner.TrackMapStatusText}" />
                            </Grid>
                            <Border Grid.Row="2"
                                    Style="{StaticResource MetricTileStyle}"
                                    Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="6" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Viewbox Height="118"
                                             Stretch="Uniform">
                                        <Viewbox.Style>
                                            <Style TargetType="{x:Type Viewbox}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasDrawableTrackMap}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Viewbox.Style>
                                        <Canvas Width="220"
                                                Height="150"
                                                ClipToBounds="True">
                                            <Rectangle Width="220"
                                                       Height="150"
                                                       RadiusX="12"
                                                       RadiusY="12"
                                                       Fill="{StaticResource TrackMapBackgroundBrush}"
                                                       Stroke="{StaticResource BorderPanelBrush}"
                                                       StrokeThickness="1" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.TrackMapPathData}"
                                                  Stroke="{StaticResource TrackMapOutlineBrush}"
                                                  StrokeThickness="3"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.TrackMapHighlightPathData}"
                                                  Stroke="{StaticResource ChartSpeedBrush}"
                                                  StrokeThickness="5"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  StrokeLineJoin="Round" />
                                            <Ellipse Canvas.Left="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerLeft}"
                                                     Canvas.Top="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerTop}"
                                                     Width="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerSize}"
                                                     Height="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerSize}"
                                                     Fill="{StaticResource TrackMapMarkerBrush}"
                                                     Stroke="{StaticResource TrackMapBackgroundBrush}"
                                                     StrokeThickness="2" />
                                            <TextBlock Canvas.Left="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerX}"
                                                       Canvas.Top="{Binding CornerAnalysis.SelectedCorner.TrackMapMarkerY}"
                                                       Margin="8,-18,0,0"
                                                       Foreground="{StaticResource FgPrimaryBrush}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding CornerAnalysis.SelectedCorner.TrackMapCornerLabelText}" />
                                        </Canvas>
                                    </Viewbox>
                                    <Border MinHeight="118"
                                            CornerRadius="10"
                                            Background="{StaticResource TrackMapBackgroundBrush}"
                                            BorderBrush="{StaticResource BorderPanelBrush}"
                                            BorderThickness="1">
                                        <Border.Style>
                                            <Style TargetType="{x:Type Border}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasDrawableTrackMap}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Margin="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource FgSecondaryBrush}"
                                                   FontWeight="SemiBold"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.TrackMapEmptyStateText}"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                    <TextBlock Grid.Row="2"
                                               Foreground="{StaticResource FgSecondaryBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding CornerAnalysis.SelectedCorner.TrackMapWarningText}"
                                               TextWrapping="Wrap"
                                               ToolTip="{Binding CornerAnalysis.SelectedCorner.TrackMapWarningText}" />
                                </Grid>
                            </Border>
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{StaticResource FgSectionBrush}"
                                           Text="{Binding CornerAnalysis.SelectedCorner.TrackMapSourceText}" />
                                <TextBlock Grid.Column="2"
                                           Foreground="{StaticResource FgSectionBrush}"
                                           HorizontalAlignment="Right"
                                           Text="{Binding CornerAnalysis.SelectedCorner.TrackMapQualityText}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <Border x:Name="CornerAnalysisVisualEvidencePanel"
                            Grid.Row="2"
                            Grid.Column="0"
                            Grid.ColumnSpan="1"
                            Style="{StaticResource GlassCardStyle}"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="8" />
                                <RowDefinition Height="72" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource SectionTitleTextStyle}"
                                       FontSize="16"
                                       Text="视觉证据" />

                            <Border Grid.Row="2"
                                    Style="{StaticResource MetricTileStyle}"
                                    Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="速度对比" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{StaticResource FgSectionBrush}"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.SpeedChartStatusText}" />
                                    </Grid>
                                    <Viewbox Grid.Row="1"
                                             Margin="0,4,0,0"
                                             Height="38"
                                             Stretch="Fill">
                                        <Viewbox.Style>
                                            <Style TargetType="{x:Type Viewbox}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasSpeedChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Viewbox.Style>
                                        <Canvas Width="220" Height="72">
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.SpeedReferencePathData}"
                                                  Stroke="{StaticResource ChartReferenceBrush}"
                                                  StrokeDashArray="4 3"
                                                  StrokeThickness="2" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.SpeedCurrentPathData}"
                                                  Stroke="{StaticResource ChartSpeedBrush}"
                                                  StrokeThickness="2.5" />
                                        </Canvas>
                                    </Viewbox>
                                    <TextBlock Grid.Row="1"
                                               Margin="0,6,0,0"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource FgSectionBrush}"
                                               FontWeight="SemiBold"
                                               Text="{Binding CornerAnalysis.SelectedCorner.SpeedChartStatusText}"
                                               TextAlignment="Center"
                                               TextWrapping="Wrap">
                                        <TextBlock.Style>
                                            <Style TargetType="{x:Type TextBlock}">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasSpeedChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                            </Border>

                            <Border Grid.Row="2"
                                    Grid.Column="2"
                                    Style="{StaticResource MetricTileStyle}"
                                    Padding="8">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Style="{StaticResource MetricLabelTextStyle}" Text="刹车对比" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{StaticResource FgSectionBrush}"
                                                   Text="{Binding CornerAnalysis.SelectedCorner.BrakeChartStatusText}" />
                                    </Grid>
                                    <Viewbox Grid.Row="1"
                                             Margin="0,4,0,0"
                                             Height="38"
                                             Stretch="Fill">
                                        <Viewbox.Style>
                                            <Style TargetType="{x:Type Viewbox}">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CornerAnalysis.SelectedCorner.HasBrakeChart}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Viewbox.Style>
                                        <Canvas Width="220" Height="72">
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.BrakeReferencePathData}"
                                                  Stroke="{StaticResource ChartReferenceBrush}"
                                                  StrokeDashArray="4 3"
                                                  StrokeThickness="2" />
                                            <Path Data="{Binding CornerAnalysis.SelectedCorner.BrakeCurrentPathData}"
                                                  Stroke="{StaticResource ChartBrakeBrush}"
                                                  StrokeThickness="2.5" />
                                        </Canvas>
