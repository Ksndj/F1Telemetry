<UserControl x:Class="F1Telemetry.App.Views.CornerAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1180">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <Style x:Key="PanelStyle" TargetType="{x:Type Border}">
            <Setter Property="Padding" Value="18" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Background" Value="#0F1B2E" />
        </Style>

        <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="#9AB0C9" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>

    <Border Padding="20"
            CornerRadius="20"
            Background="#08111F">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="126" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="弯角分析" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextStyle}"
                                   Text="{Binding CornerAnalysis.StatusText}" />
                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox MinWidth="260"
                                      Height="34"
                                      DisplayMemberPath="SummaryText"
                                      ItemsSource="{Binding CornerAnalysis.HistoryBrowser.HistorySessions}"
                                      SelectedItem="{Binding CornerAnalysis.HistoryBrowser.SelectedSession, Mode=TwoWay}" />
                            <ComboBox Grid.Column="2"
                                      Height="34"
                                      DisplayMemberPath="LapText"
                                      ItemsSource="{Binding CornerAnalysis.HistoryBrowser.HistoryLaps}"
                                      SelectedItem="{Binding CornerAnalysis.SelectedLap, Mode=TwoWay}" />
                            <TextBlock Grid.Column="4"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="{Binding CornerAnalysis.SelectionText}" />
                        </Grid>
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="112"
                            Height="36"
                            HorizontalAlignment="Right"
                            Command="{Binding CornerAnalysis.RefreshCommand}"
                            Content="刷新分析" />
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Style="{StaticResource PanelStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Style="{StaticResource MutedTextStyle}"
                               Text="{Binding CornerAnalysis.EmptyStateText}" />

                    <ListView Grid.Row="2"
                              Background="Transparent"
                              BorderThickness="0"
                              ItemsSource="{Binding CornerAnalysis.CornerRows}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="190"
                                                DisplayMemberBinding="{Binding CornerText}"
                                                Header="弯角" />
                                <GridViewColumn Width="120"
                                                DisplayMemberBinding="{Binding MinimumSpeedText}"
                                                Header="最低速度" />
                                <GridViewColumn Width="160"
                                                DisplayMemberBinding="{Binding SpeedWindowText}"
                                                Header="入弯/出弯" />
                                <GridViewColumn Width="90"
                                                DisplayMemberBinding="{Binding BrakeText}"
                                                Header="最大刹车" />
                                <GridViewColumn Width="120"
                                                DisplayMemberBinding="{Binding TimeLossText}"
                                                Header="损失" />
                                <GridViewColumn Width="100"
                                                DisplayMemberBinding="{Binding ConfidenceText}"
                                                Header="置信度" />
                                <GridViewColumn Width="320"
                                                DisplayMemberBinding="{Binding WarningText}"
                                                Header="数据限制" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
