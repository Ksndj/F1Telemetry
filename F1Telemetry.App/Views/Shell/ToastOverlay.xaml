<UserControl x:Class="F1Telemetry.App.Views.Shell.ToastOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <Border x:Name="WindowStateToast"
            Margin="0,24,24,0"
            Padding="14,10"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Background="{StaticResource ToastBackgroundBrush}"
            BorderBrush="{StaticResource ToastBorderBrush}"
            BorderThickness="1"
            CornerRadius="14"
            Opacity="0"
            Visibility="Collapsed">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WindowStateToastScaleTransform"
                                ScaleX="0.96"
                                ScaleY="0.96" />
                <TranslateTransform x:Name="WindowStateToastTranslateTransform"
                                    Y="-6" />
            </TransformGroup>
        </Border.RenderTransform>
        <TextBlock x:Name="WindowStateToastText"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Foreground="{StaticResource ToastForegroundBrush}"
                   Text="窗口状态已更新" />
    </Border>
</UserControl>
