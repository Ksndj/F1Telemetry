<UserControl x:Class="F1Telemetry.App.Views.Shell.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="SidebarRoot"
            CornerRadius="18"
            Background="{StaticResource BgPanelBrush}">
        <Border.Style>
            <Style TargetType="{x:Type Border}">
                <Setter Property="Margin" Value="16,16,0,16" />
                <Setter Property="Padding" Value="14" />
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                        <Setter Property="Margin" Value="10,16,0,16" />
                        <Setter Property="Padding" Value="8" />
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <Button x:Name="SidebarToggleButton"
                        Command="{Binding ToggleSidebarCommand}"
                        ToolTip="展开 / 收起侧边栏">
                    <Button.Style>
                        <Style BasedOn="{StaticResource ShellIconButtonStyle}"
                               TargetType="{x:Type Button}">
                            <Setter Property="HorizontalAlignment" Value="Right" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                    <Setter Property="HorizontalAlignment" Value="Center" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               FontSize="15"
                               Text="&#xE700;" />
                </Button>

                <Border x:Name="SidebarLogo"
                        Width="120"
                        Height="96"
                        HorizontalAlignment="Center"
                        Background="{StaticResource BgDeepBrush}"
                        CornerRadius="20">
                    <Border.Style>
                        <Style TargetType="{x:Type Border}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Image Margin="10"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Source="/F1Telemetry.App;component/Assets/AppIcon.png"
                           Stretch="Uniform" />
                </Border>

                <TextBlock x:Name="SidebarProductName"
                           Margin="0,4,0,0"
                           HorizontalAlignment="Center"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FgPrimaryBrush}"
                           Text="F1 Telemetry">
                    <TextBlock.Style>
                        <Style TargetType="{x:Type TextBlock}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <ListBox x:Name="ShellNavigationList"
                     Grid.Row="1"
                     Margin="0,22,0,0"
                     Background="{StaticResource TransparentBrush}"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Hidden"
                     ItemContainerStyle="{StaticResource ShellNavigationItemStyle}"
                     ItemsSource="{Binding ShellNavigationItems}"
                     SelectedItem="{Binding SelectedShellNavigationItem, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid x:Name="NavigationItemLayout"
                              ToolTip="{Binding Name}">
                            <Grid.Style>
                                <Style TargetType="{x:Type Grid}">
                                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                            <Setter Property="Width" Value="44" />
                                            <Setter Property="Height" Value="44" />
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="24" />
                                <ColumnDefinition Width="10" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock x:Name="NavigationItemIcon"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="17"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=Foreground}"
                                       Text="{Binding IconGlyph}">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                                <Setter Property="Grid.ColumnSpan" Value="3" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock x:Name="NavigationItemText"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type ListBoxItem}}, Path=Foreground}"
                                       Text="{Binding Name}">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.IsSidebarExpanded, RelativeSource={RelativeSource AncestorType={x:Type Window}}}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border x:Name="SidebarStatusCard"
                    Grid.Row="2"
                    CornerRadius="14"
                    Background="{StaticResource BgInputBrush}"
                    ToolTip="{Binding SidebarUdpStatusTooltip}">
                <Border.Style>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="Padding" Value="12,14" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                <Setter Property="Padding" Value="8" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Foreground="{StaticResource StatusSuccessBrush}"
                               Text="{Binding ConnectionStateText}">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Margin="0,12,0,0"
                               Foreground="{StaticResource FgSectionBrush}"
                               Text="{Binding SidebarUdpPortText}">
                        <TextBlock.Style>
                            <Style TargetType="{x:Type TextBlock}">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <StackPanel x:Name="SidebarCompactStatusRow"
                                HorizontalAlignment="Center"
                                Orientation="Vertical">
                        <StackPanel.Style>
                            <Style TargetType="{x:Type StackPanel}">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarExpanded}" Value="False">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <Ellipse x:Name="CompactSidebarStatusDot"
                                 Width="8"
                                 Height="8"
                                 HorizontalAlignment="Center"
                                 Fill="{StaticResource StatusSuccessBrush}" />
                        <TextBlock x:Name="CompactSidebarUdpLabel"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Center"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgSectionBrush}"
                                   Text="UDP" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
