<UserControl x:Class="F1Telemetry.App.Views.LapHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="1120">
    <ScrollViewer x:Name="LapHistoryScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <Border MinWidth="980"
                Padding="20"
                CornerRadius="20"
                Background="#0F1B2E">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="单圈历史" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#9AB0C9"
                           Text="缓存保留整场圈摘要，界面默认显示最近 12 圈，最新圈在最上方。"
                           TextWrapping="Wrap" />

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="14" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Padding="14"
                            CornerRadius="14"
                            Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="Best" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="White"
                                       Text="{Binding BestLapSummaryText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Padding="14"
                            CornerRadius="14"
                            Background="#132743">
                        <StackPanel>
                            <TextBlock Foreground="#7FA5D8" Text="Last" />
                            <TextBlock Margin="0,6,0,0"
                                       Foreground="White"
                                       Text="{Binding LastLapSummaryText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>

                <ItemsControl Margin="0,18,0,0"
                              ItemsSource="{Binding RecentLapSummaries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="14"
                                    CornerRadius="14"
                                    Background="#132743">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="92" />
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="74" />
                                        <ColumnDefinition Width="76" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="96" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Foreground="White" Text="{Binding LapText}" />
                                    <TextBlock Grid.Column="1" Foreground="#D7E4F3" Text="{Binding LapTimeText}" />
                                    <TextBlock Grid.Column="2" Foreground="#D7E4F3" Text="{Binding SectorsText}" />
                                    <TextBlock Grid.Column="3" Foreground="#D7E4F3" Text="{Binding AverageSpeedText}" />
                                    <TextBlock Grid.Column="4" Foreground="#D7E4F3" Text="{Binding FuelUsedLitresText}" />
                                    <TextBlock Grid.Column="5" Foreground="#D7E4F3" Text="{Binding ErsUsedText}" />
                                    <TextBlock Grid.Column="6" Foreground="#D7E4F3" Text="{Binding TyreWearDeltaText}" />
                                    <TextBlock Grid.Column="7" Foreground="#7FA5D8" Text="{Binding ValidityText}" />
                                    <TextBlock Grid.Column="8" Foreground="#D7E4F3" Text="{Binding TyreWindowText}" />
                                    <TextBlock Grid.Column="9" Foreground="#D7E4F3" Text="{Binding PitWindowText}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
