<UserControl x:Class="F1Telemetry.App.Views.OpponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="1120">
    <ScrollViewer x:Name="OpponentsScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <Border MinWidth="760"
                Padding="20"
                CornerRadius="20"
                Background="#0F1B2E">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="对手列表" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#9AB0C9"
                           Text="车手、位置、轮胎、胎龄、Pit 状态、与我差距。"
                           TextWrapping="Wrap" />

                <Border Margin="0,18,0,0"
                        Padding="16"
                        CornerRadius="16"
                        Background="#132743">
                    <StackPanel>
                        <TextBlock Foreground="#7FA5D8" Text="前后车差距" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="White"
                                   Text="{Binding PlayerGapText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ItemsControl Margin="0,18,0,0"
                              ItemsSource="{Binding OpponentCars}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="14"
                                    CornerRadius="14"
                                    Background="#132743">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="86" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Foreground="White" Text="{Binding DisplayName}" />
                                    <TextBlock Grid.Column="1" Foreground="#D7E4F3" Text="{Binding PositionText}" />
                                    <TextBlock Grid.Column="2" Foreground="#D7E4F3" Text="{Binding TyreText}" />
                                    <TextBlock Grid.Column="3" Foreground="#D7E4F3" Text="{Binding TyreAgeText}" />
                                    <TextBlock Grid.Column="4" Foreground="#D7E4F3" Text="{Binding PitStatusText}" />
                                    <TextBlock Grid.Column="5" Foreground="#7FA5D8" Text="{Binding GapToPlayerText}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
