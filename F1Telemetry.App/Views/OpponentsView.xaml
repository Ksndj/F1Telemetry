<UserControl x:Class="F1Telemetry.App.Views.OpponentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="680"
             d:DesignWidth="1120">
    <ScrollViewer x:Name="OpponentsScrollViewer"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <Border MinWidth="760"
                Padding="20"
                CornerRadius="20"
                Background="{StaticResource BgPanelBrush}">
            <StackPanel>
                <TextBlock FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FgPrimaryBrush}"
                           Text="对手列表" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource FgSectionBrush}"
                           Text="车手、位置、轮胎、胎龄、Pit 状态、与我差距、上一圈对比。"
                           TextWrapping="Wrap" />

                <Border Margin="0,18,0,0"
                        Padding="16"
                        CornerRadius="16"
                        Background="{StaticResource BgCardBrush}">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="前后车差距" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="{Binding PlayerGapText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Margin="0,12,0,0"
                        Padding="16"
                        CornerRadius="16"
                        Background="{StaticResource BgCardBrush}">
                    <StackPanel>
                        <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="上一圈对比" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="{Binding OverviewLapComparisonText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <ItemsControl Margin="0,18,0,0"
                              ItemsSource="{Binding OpponentCars}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,10"
                                    Padding="14"
                                    CornerRadius="14"
                                    Background="{StaticResource BgCardBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="52" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="64" />
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="86" />
                                        <ColumnDefinition Width="88" />
                                        <ColumnDefinition Width="132" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding DisplayName}" />
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding PositionText}" />
                                    <TextBlock Grid.Column="2" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding TyreText}" />
                                    <TextBlock Grid.Column="3" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding TyreAgeText}" />
                                    <TextBlock Grid.Column="4" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding PitStatusText}" />
                                    <TextBlock Grid.Column="5" Foreground="{StaticResource FgLabelBrush}" Text="{Binding GapToPlayerText}" />
                                    <TextBlock Grid.Column="6" Foreground="{StaticResource FgLabelBrush}" Text="{Binding LastLapText}" />
                                    <TextBlock Grid.Column="7" Foreground="{StaticResource FgLabelBrush}" Text="{Binding LapComparisonText}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
