<UserControl x:Class="F1Telemetry.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1100">
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Padding="20"
                    CornerRadius="18"
                    Background="#0F1B2E">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="设置" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9AB0C9"
                               Text="通用配置与发布入口"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#7FA5D8" Text="UDP 端口" />
                        <TextBlock Grid.Column="1"
                                   Foreground="#D7E4F3"
                                   Text="{Binding PortText}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,14,0,0"
                                   Foreground="#7FA5D8"
                                   Text="监听中端口" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,14,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding ListeningPortText}" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,14,0,0"
                                   Foreground="#7FA5D8"
                                   Text="连接状态" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,14,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding ConnectionStateText}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,14,0,0"
                                   Foreground="#7FA5D8"
                                   Text="状态消息" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,14,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="#0F1B2E">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="UDP Raw Log" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Foreground="#D7E4F3"
                                  Content="启用 UDP Raw Log"
                                  IsChecked="{Binding UdpRawLogEnabled, Mode=TwoWay}" />
                        <Button Grid.Column="1"
                                Width="120"
                                Height="32"
                                Command="{Binding OpenUdpRawLogDirectoryCommand}"
                                Content="打开日志目录" />
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#7FA5D8" Text="状态" />
                        <TextBlock Grid.Column="1"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogStatusText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="日志目录" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogDirectoryText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="最近文件" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogLastFilePathText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="文件大小" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogLastFileSizeText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="4"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="最近写入时间" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogLastWriteTimeText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="5"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="已记录 / 丢弃" />
                        <TextBlock Grid.Row="5"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3">
                            <Run Text="{Binding UdpRawLogWrittenPacketCount, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding UdpRawLogDroppedPacketCount, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock Grid.Row="6"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="最近错误" />
                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogLastErrorText}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="#0F1B2E">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="版本与更新" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="当前版本" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="18"
                                   Foreground="#D7E4F3"
                                   Text="{Binding ApplicationVersionText}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="140"
                            Height="36"
                            VerticalAlignment="Center"
                            Command="{Binding DownloadLatestVersionCommand}"
                            Content="下载最新版本" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
