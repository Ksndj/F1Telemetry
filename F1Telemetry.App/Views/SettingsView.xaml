<UserControl x:Class="F1Telemetry.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1100">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <Border Padding="20"
                    CornerRadius="18"
                    Background="#0F1B2E">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="设置" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9AB0C9"
                               Text="通用配置与发布入口"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#7FA5D8" Text="UDP 端口" />
                        <TextBlock Grid.Column="1"
                                   Foreground="#D7E4F3"
                                   Text="{Binding PortText}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,14,0,0"
                                   Foreground="#7FA5D8"
                                   Text="监听中端口" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,14,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding ListeningPortText}" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,14,0,0"
                                   Foreground="#7FA5D8"
                                   Text="连接状态" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,14,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding ConnectionStateText}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,14,0,0"
                                   Foreground="#7FA5D8"
                                   Text="状态消息" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,14,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding StatusMessage}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="#0F1B2E">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="App 日志" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <CheckBox Foreground="#D7E4F3"
                                      Content="App 分类日志"
                                      IsChecked="{Binding EnableAppFileLog, Mode=TwoWay}" />
                            <CheckBox Margin="18,0,0,0"
                                      Foreground="#D7E4F3"
                                      Content="RaceAssistant 问答记录"
                                      IsChecked="{Binding EnableRaceAssistantAuditLog, Mode=TwoWay}" />
                            <CheckBox Margin="18,0,0,0"
                                      Foreground="#D7E4F3"
                                      Content="Prompt 摘要"
                                      IsChecked="{Binding RaceAssistantLogPromptSummary, Mode=TwoWay}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Width="120"
                                Height="32"
                                Margin="12,0,0,0"
                                Command="{Binding OpenAppLogDirectoryCommand}"
                                Content="打开 App 日志" />
                        <Button Grid.Column="2"
                                Width="148"
                                Height="32"
                                Margin="8,0,0,0"
                                Command="{Binding OpenRaceAssistantLogDirectoryCommand}"
                                Content="打开问答日志" />
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#7FA5D8" Text="App 日志目录" />
                        <TextBlock Grid.Column="1"
                                   Foreground="#D7E4F3"
                                   Text="{Binding AppLogDirectoryText, Mode=OneWay}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="App 最近文件" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding AppLogLastFilePathText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="App 文件大小" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding AppLogLastFileSizeText, Mode=OneWay}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="App 最近写入" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding AppLogLastWriteTimeText, Mode=OneWay}" />

                        <TextBlock Grid.Row="4"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="问答日志目录" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding RaceAssistantLogDirectoryText, Mode=OneWay}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="5"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="问答最近文件" />
                        <TextBlock Grid.Row="5"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding RaceAssistantLogLastFilePathText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="6"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="问答文件状态" />
                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3">
                            <Run Text="{Binding RaceAssistantLogLastFileSizeText, Mode=OneWay}" />
                            <Run Text=" · " />
                            <Run Text="{Binding RaceAssistantLogLastWriteTimeText, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock Grid.Column="2"
                                   Foreground="#7FA5D8"
                                   Text="最大 MB" />
                        <TextBox Grid.Column="3"
                                 Height="30"
                                 Text="{Binding MaxLogFileSizeMbText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="保留天数" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="3"
                                 Margin="0,8,0,0"
                                 Height="30"
                                 Text="{Binding MaxLogRetentionDaysText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="状态" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="3"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding LogSettingsStatusText}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="#0F1B2E">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="UDP Raw Log" />
                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox Foreground="#D7E4F3"
                                  Content="启用 UDP Raw Log"
                                  IsChecked="{Binding UdpRawLogEnabled, Mode=TwoWay}" />
                        <Button Grid.Column="1"
                                Width="120"
                                Height="32"
                                Command="{Binding OpenUdpRawLogDirectoryCommand}"
                                Content="打开日志目录" />
                    </Grid>

                    <Grid Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#7FA5D8" Text="状态" />
                        <TextBlock Grid.Column="1"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogStatusText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="日志目录" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogDirectoryText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="最近文件" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogLastFilePathText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="文件大小" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogLastFileSizeText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="4"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="最近写入时间" />
                        <TextBlock Grid.Row="4"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogLastWriteTimeText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="5"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="已记录 / 丢弃" />
                        <TextBlock Grid.Row="5"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3">
                            <Run Text="{Binding UdpRawLogWrittenPacketCount, Mode=OneWay}" />
                            <Run Text=" / " />
                            <Run Text="{Binding UdpRawLogDroppedPacketCount, Mode=OneWay}" />
                        </TextBlock>

                        <TextBlock Grid.Row="6"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="最近错误" />
                        <TextBlock Grid.Row="6"
                                   Grid.Column="1"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding UdpRawLogLastErrorText}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="#0F1B2E">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Text="方向盘语音 AI" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#9AB0C9"
                               Text="按键触发麦克风提问与 TTS 回答"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="320" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="#7FA5D8"
                                   Text="功能开关" />
                        <CheckBox Grid.Column="1"
                                  Foreground="#D7E4F3"
                                  Content="启用语音 AI"
                                  IsChecked="{Binding VoiceAiEnabled, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,14,0,0"
                                   Foreground="#7FA5D8"
                                   Text="方向盘按钮" />
                        <StackPanel Grid.Row="1"
                                    Grid.Column="1"
                                    Margin="0,14,12,0"
                                    Orientation="Horizontal">
                            <Button MinWidth="96"
                                    Padding="12,7"
                                    Command="{Binding BindVoiceAiInputCommand}"
                                    Content="绑定按钮" />
                            <Button MinWidth="72"
                                    Margin="8,0,0,0"
                                    Padding="12,7"
                                    Command="{Binding ClearVoiceAiInputCommand}"
                                    Content="清除" />
                        </StackPanel>
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Margin="0,14,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#D7E4F3"
                                   Text="{Binding VoiceAiBindingText}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="说话模式" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Margin="0,12,12,0"
                                  Padding="8,5"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding VoiceAiTalkModeOptions}"
                                  SelectedItem="{Binding SelectedVoiceAiTalkModeOption, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Margin="0,12,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#9AB0C9"
                                   Text="{Binding SelectedVoiceAiTalkModeOption.Description}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="麦克风" />
                        <StackPanel Grid.Row="3"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Margin="0,12,0,0"
                                    Orientation="Horizontal">
                            <ComboBox Width="320"
                                      Padding="8,5"
                                      DisplayMemberPath="DisplayName"
                                      ItemsSource="{Binding VoiceAiMicrophoneDevices}"
                                      SelectedValue="{Binding VoiceAiMicrophoneDeviceId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      SelectedValuePath="DeviceId" />
                            <Button MinWidth="72"
                                    Margin="8,0,0,0"
                                    Padding="12,7"
                                    Command="{Binding RefreshMicrophonesCommand}"
                                    Content="刷新" />
                            <Button MinWidth="96"
                                    Margin="8,0,0,0"
                                    Padding="12,7"
                                    Command="{Binding TestMicrophoneCommand}"
                                    Content="测试" />
                        </StackPanel>

                        <TextBlock Grid.Row="4"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="音频处理" />
                        <WrapPanel Grid.Row="4"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="0,12,0,0">
                            <CheckBox Margin="0,0,16,6"
                                      Foreground="#D7E4F3"
                                      Content="启用麦克风降噪"
                                      IsChecked="{Binding VoiceAiNoiseReductionEnabled, Mode=TwoWay}" />
                            <CheckBox Margin="0,0,16,6"
                                      Foreground="#D7E4F3"
                                      Content="启用风噪过滤"
                                      IsChecked="{Binding VoiceAiHighPassFilterEnabled, Mode=TwoWay}" />
                            <CheckBox Margin="0,0,16,6"
                                      Foreground="#D7E4F3"
                                      Content="启用噪声门"
                                      IsChecked="{Binding VoiceAiNoiseGateEnabled, Mode=TwoWay}" />
                            <CheckBox Margin="0,0,16,6"
                                      Foreground="#D7E4F3"
                                      Content="启用 VAD"
                                      IsChecked="{Binding VoiceAiVadEnabled, Mode=TwoWay}" />
                            <CheckBox Margin="0,0,16,6"
                                      Foreground="#D7E4F3"
                                      Content="启用自动增益"
                                      IsChecked="{Binding VoiceAiAutoGainEnabled, Mode=TwoWay}" />
                        </WrapPanel>

                        <TextBlock Grid.Row="5"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="降噪参数" />
                        <WrapPanel Grid.Row="5"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="0,12,0,0">
                            <TextBlock Margin="0,6,6,0"
                                       Foreground="#9AB0C9"
                                       Text="高通 Hz" />
                            <TextBox Width="72"
                                     Margin="0,0,16,0"
                                     Padding="8,5"
                                     Text="{Binding VoiceAiHighPassCutoffHzText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,6,6,0"
                                       Foreground="#9AB0C9"
                                       Text="噪声门 dB" />
                            <TextBox Width="72"
                                     Margin="0,0,16,0"
                                     Padding="8,5"
                                     Text="{Binding VoiceAiNoiseGateThresholdDbText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,6,6,0"
                                       Foreground="#9AB0C9"
                                       Text="最长秒" />
                            <TextBox Width="64"
                                     Margin="0,0,16,0"
                                     Padding="8,5"
                                     Text="{Binding VoiceAiMaxRecordingSecondsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,6,6,0"
                                       Foreground="#9AB0C9"
                                       Text="最低置信度" />
                            <TextBox Width="72"
                                     Padding="8,5"
                                     Text="{Binding VoiceAiMinRecognitionConfidenceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </WrapPanel>

                        <TextBlock Grid.Row="6"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="VAD 裁剪" />
                        <WrapPanel Grid.Row="6"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="0,12,0,0">
                            <TextBlock Margin="0,6,6,0"
                                       Foreground="#9AB0C9"
                                       Text="前置 ms" />
                            <TextBox Width="72"
                                     Margin="0,0,16,0"
                                     Padding="8,5"
                                     Text="{Binding VoiceAiPreSpeechPaddingMsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,6,6,0"
                                       Foreground="#9AB0C9"
                                       Text="后置 ms" />
                            <TextBox Width="72"
                                     Margin="0,0,16,0"
                                     Padding="8,5"
                                     Text="{Binding VoiceAiPostSpeechPaddingMsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Margin="0,6,6,0"
                                       Foreground="#9AB0C9"
                                       Text="最短人声 ms" />
                            <TextBox Width="72"
                                     Padding="8,5"
                                     Text="{Binding VoiceAiMinSpeechDurationMsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </WrapPanel>

                        <TextBlock Grid.Row="7"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="输入电平" />
                        <ProgressBar Grid.Row="7"
                                     Grid.Column="1"
                                     Margin="0,14,12,0"
                                     Height="12"
                                     Maximum="1"
                                     Minimum="0"
                                     Value="{Binding VoiceAiMicrophoneTestLevel, Mode=OneWay}" />
                        <TextBlock Grid.Row="7"
                                   Grid.Column="2"
                                   Margin="0,12,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#D7E4F3"
                                   Text="{Binding VoiceAiMicrophoneStatusText}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="8"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="运行状态" />
                        <TextBlock Grid.Row="8"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding VoiceAiStatusText}"
                                   TextTrimming="CharacterEllipsis"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="9"
                                   Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="识别状态" />
                        <TextBlock Grid.Row="9"
                                   Grid.Column="1"
                                   Grid.ColumnSpan="2"
                                   Margin="0,12,0,0"
                                   Foreground="#D7E4F3"
                                   Text="{Binding VoiceAiRecognitionStatusDetailText, Mode=OneWay}"
                                   TextWrapping="Wrap" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="#0F1B2E">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Text="版本与更新" />
                        <TextBlock Margin="0,12,0,0"
                                   Foreground="#7FA5D8"
                                   Text="当前版本" />
                        <TextBlock Margin="0,4,0,0"
                                   FontSize="18"
                                   Foreground="#D7E4F3"
                                   Text="{Binding ApplicationVersionText}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="140"
                            Height="36"
                            VerticalAlignment="Center"
                            Command="{Binding DownloadLatestVersionCommand}"
                            Content="下载最新版本" />
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
