<UserControl x:Class="F1Telemetry.App.Views.Controls.TelemetryChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="240"
             d:DesignWidth="420">
    <Border Padding="18"
            CornerRadius="18"
            Background="#132743">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Text="{Binding Title}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#9AB0C9"
                           Text="{Binding XAxisLabel}" />
            </StackPanel>

            <Grid Grid.Row="1"
                  Margin="0,16,0,0">
                <Border x:Name="EmptyStateBorder"
                        CornerRadius="14"
                        Background="#0C1830">
                    <TextBlock x:Name="EmptyStateTextBlock"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="#7FA5D8"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                </Border>

                <Border x:Name="PlotBorder"
                        Padding="6"
                        CornerRadius="14"
                        Background="#0C1830" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
