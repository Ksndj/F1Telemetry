<UserControl x:Class="F1Telemetry.App.Views.Controls.TelemetryChartControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="240"
             d:DesignWidth="420">
    <Border Padding="18"
            CornerRadius="18"
            Background="{StaticResource BgCardBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FgPrimaryBrush}"
                           Text="{Binding Title}" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="{StaticResource FgSectionBrush}"
                           Text="{Binding XAxisLabel}" />
            </StackPanel>

            <Grid x:Name="ChartSurfaceGrid"
                  Grid.Row="1"
                  Margin="0,16,0,0">
                <Border x:Name="EmptyStateBorder"
                        CornerRadius="14"
                        Background="{StaticResource BgMetricTileBrush}">
                    <TextBlock x:Name="EmptyStateTextBlock"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FgLabelBrush}"
                               TextWrapping="Wrap"
                               TextAlignment="Center" />
                </Border>

                <Border x:Name="PlotBorder"
                        Padding="6"
                        CornerRadius="14"
                        Background="{StaticResource BgMetricTileBrush}" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
