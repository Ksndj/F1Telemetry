<UserControl x:Class="F1Telemetry.App.Views.AiTtsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:attached="clr-namespace:F1Telemetry.App.AttachedProperties"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="720"
             d:DesignWidth="1100">
    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="20"
                    CornerRadius="18"
                    Background="{StaticResource BgPanelBrush}">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               Text="AI 设置" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource FgSectionBrush}"
                               Text="DeepSeek 分析配置与连接状态"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="AI 开关" />
                        <CheckBox Grid.Column="1"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding AiEnabled}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource FgLabelBrush}"
                                   Text="Base URL" />
                        <TextBox Grid.Row="1"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,14,0,0"
                                 Padding="8,5"
                                 Text="{Binding AiBaseUrl, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource FgLabelBrush}"
                                   Text="Model" />
                        <TextBox Grid.Row="2"
                                 Grid.Column="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,14,0,0"
                                 Padding="8,5"
                                 Text="{Binding AiModel, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource FgLabelBrush}"
                                   Text="API Key" />
                        <PasswordBox Grid.Row="3"
                                     Grid.Column="1"
                                     Margin="0,14,10,0"
                                     Padding="8,5"
                                     attached:PasswordBoxBinding.BoundPassword="{Binding AiApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <StackPanel Grid.Row="3"
                                    Grid.Column="2"
                                    Margin="0,14,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Foreground="{StaticResource FgSectionBrush}"
                                       Text="{Binding AiApiKeyStatusText}" />
                            <TextBlock Margin="0,3,0,0"
                                       Foreground="{StaticResource FgLabelBrush}"
                                       Text="{Binding AiSettingsSaveStatusText}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="16,0,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="{StaticResource BgPanelBrush}">
                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               Text="TTS 语音播报" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{StaticResource FgSectionBrush}"
                               Text="语音播报开关、音色、音量与语速"
                               TextWrapping="Wrap" />

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="TTS 开关" />
                        <CheckBox Grid.Column="1"
                                  VerticalAlignment="Center"
                                  IsChecked="{Binding TtsEnabled}" />

                        <TextBlock Grid.Row="1"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource FgLabelBrush}"
                                   Text="Voice" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  Margin="0,14,12,0"
                                  Padding="8,5"
                                  IsEnabled="{Binding HasAvailableVoices}"
                                  ItemsSource="{Binding AvailableVoices}"
                                  SelectedItem="{Binding TtsVoiceName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Row="1"
                                   Grid.Column="2"
                                   Margin="0,14,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FgSectionBrush}"
                                   Text="{Binding TtsVoiceStatusText}"
                                   TextWrapping="Wrap" />

                        <TextBlock Grid.Row="2"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource FgLabelBrush}"
                                   Text="Volume" />
                        <Slider Grid.Row="2"
                                Grid.Column="1"
                                Margin="0,14,12,0"
                                Minimum="0"
                                Maximum="100"
                                TickFrequency="5"
                                IsSnapToTickEnabled="True"
                                Value="{Binding TtsVolume}" />
                        <TextBlock Grid.Row="2"
                                   Grid.Column="2"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource FgSecondaryBrush}"
                                   Text="{Binding TtsVolume, StringFormat={}{0}%}" />

                        <TextBlock Grid.Row="3"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource FgLabelBrush}"
                                   Text="Rate" />
                        <Slider Grid.Row="3"
                                Grid.Column="1"
                                Margin="0,14,12,0"
                                Minimum="-10"
                                Maximum="10"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                Value="{Binding TtsRate}" />
                        <TextBlock Grid.Row="3"
                                   Grid.Column="2"
                                   Margin="0,14,0,0"
                                   Foreground="{StaticResource FgSecondaryBrush}"
                                   Text="{Binding TtsRate}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="{StaticResource BgPanelBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               Text="赛前轮胎库存" />
                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Right"
                               Foreground="{StaticResource FgLabelBrush}"
                               Text="{Binding RaceWeekendTyrePlanStatusText}"
                               TextWrapping="Wrap" />

                    <TextBlock Grid.Row="1"
                               Margin="0,12,18,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FgSectionBrush}"
                               Text="{Binding RaceWeekendTyreSetsStatusText}"
                               TextWrapping="Wrap" />
                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Padding="12,7"
                                Command="{Binding ReadTyreSetsInventoryCommand}"
                                Content="自动读取 TyreSets" />
                        <Button Margin="0,0,8,0"
                                Padding="12,7"
                                Command="{Binding ClearTyreInventoryCommand}"
                                Content="清零" />
                        <Button Padding="12,7"
                                Command="{Binding SaveTyreInventoryCommand}"
                                Content="保存" />
                    </StackPanel>

                    <ItemsControl Grid.Row="2"
                                  Grid.ColumnSpan="2"
                                  Margin="0,14,0,0"
                                  ItemsSource="{Binding RaceWeekendTyreInventoryItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="188"
                                        MinHeight="112"
                                        Margin="0,0,10,10"
                                        Padding="14"
                                        CornerRadius="12"
                                        Background="{StaticResource BgCardBrush}"
                                        BorderBrush="{StaticResource BorderPanelBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="10"
                                                Height="34"
                                                CornerRadius="5"
                                                Background="{Binding AccentBrush}" />
                                        <StackPanel Grid.Column="1"
                                                    Margin="10,0,0,0">
                                            <TextBlock Foreground="{StaticResource FgPrimaryBrush}"
                                                       FontWeight="SemiBold"
                                                       Text="{Binding DisplayName}" />
                                            <TextBlock Margin="0,3,0,0"
                                                       Foreground="{StaticResource FgLabelBrush}"
                                                       Text="{Binding EnglishName}" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="2"
                                                    Grid.ColumnSpan="2"
                                                    Margin="0,16,0,0"
                                                    Orientation="Horizontal">
                                            <Button Width="30"
                                                    Height="30"
                                                    Command="{Binding DecrementCommand}"
                                                    Content="-" />
                                            <TextBox Width="46"
                                                     Height="30"
                                                     Margin="8,0"
                                                     Padding="4,3"
                                                     HorizontalContentAlignment="Center"
                                                     MaxLength="2"
                                                     Text="{Binding CountText, UpdateSourceTrigger=PropertyChanged}" />
                                            <Button Width="30"
                                                    Height="30"
                                                    Command="{Binding IncrementCommand}"
                                                    Content="+" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Grid.Row="3"
                                Grid.ColumnSpan="2"
                                Margin="0,8,0,0">
                        <TextBlock Foreground="{StaticResource FgLabelBrush}"
                                   Text="推荐磨损上限" />
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="56" />
                            </Grid.ColumnDefinitions>
                            <Slider Minimum="0"
                                    Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Value="{Binding RaceWeekendTyreMaxWearPercent}" />
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource FgSecondaryBrush}"
                                       Text="{Binding RaceWeekendTyreMaxWearPercent, StringFormat={}{0}%}" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2"
                    Grid.ColumnSpan="2"
                    Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="8"
                    Background="{StaticResource BgPanelBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FgPrimaryBrush}"
                                   Text="问工程师" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource FgSectionBrush}"
                                   Text="{Binding VoiceAssistantStatusText}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                    <StackPanel Grid.Column="1"
                                HorizontalAlignment="Right"
                                Orientation="Horizontal">
                        <CheckBox Margin="0,0,16,0"
                                  VerticalAlignment="Center"
                                  Content="启用"
                                  Foreground="{StaticResource FgSecondaryBrush}"
                                  IsChecked="{Binding VoiceAssistantEnabled}" />
                        <CheckBox VerticalAlignment="Center"
                                  Content="播报回答"
                                  Foreground="{StaticResource FgSecondaryBrush}"
                                  IsChecked="{Binding VoiceAssistantEnableTtsAnswer}" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox MinHeight="38"
                                 Padding="10,7"
                                 Text="{Binding VoiceAssistantQuestionText, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                MinWidth="96"
                                Margin="10,0,0,0"
                                Padding="14,8"
                                Command="{Binding AskRaceAssistantQuestionCommand}"
                                Content="发送" />
                        <Button Grid.Column="2"
                                MinWidth="96"
                                Margin="8,0,0,0"
                                Padding="14,8"
                                Command="{Binding ToggleRaceAssistantVoiceCommand}"
                                Content="问工程师" />
                        <Button Grid.Column="3"
                                MinWidth="80"
                                Margin="8,0,0,0"
                                Padding="14,8"
                                Command="{Binding CancelRaceAssistantQuestionCommand}"
                                Content="取消" />
                    </Grid>

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="2"
                          Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.1*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.ColumnSpan="2"
                                   Margin="0,0,0,10"
                                   Foreground="{StaticResource StatusWarningBrush}"
                                   Text="{Binding VoiceAssistantTelemetryNoticeText}"
                                   TextWrapping="Wrap" />

                        <Border Grid.Row="1"
                                Padding="14"
                                CornerRadius="8"
                                Background="{StaticResource BgCardBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="112" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="识别文本" />
                                <TextBlock Grid.Column="1"
                                           Foreground="{StaticResource FgSecondaryBrush}"
                                           Text="{Binding VoiceAssistantRecognizedText}"
                                           TextWrapping="Wrap" />
                                <TextBlock Grid.Row="1" Margin="0,8,0,0" Foreground="{StaticResource FgLabelBrush}" Text="意图类型" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding VoiceAssistantIntentText}" />
                                <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="{StaticResource FgLabelBrush}" Text="模式" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding VoiceAssistantModeText}" />
                                <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="{StaticResource FgLabelBrush}" Text="策略类型" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource FgSecondaryBrush}" Text="{Binding VoiceAssistantAdviceTypeText}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="4" Margin="0,8,0,0" Foreground="{StaticResource FgLabelBrush}" Text="建议摘要" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding VoiceAssistantSummaryText}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="5" Margin="0,8,0,0" Foreground="{StaticResource FgLabelBrush}" Text="建议动作" />
                                <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,8,0,0" Foreground="{StaticResource FgPrimaryBrush}" Text="{Binding VoiceAssistantRecommendedActionText}" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="6" Margin="0,8,0,0" Foreground="{StaticResource FgLabelBrush}" Text="置信度 / 风险" />
                                <StackPanel Grid.Row="6"
                                            Grid.Column="1"
                                            Margin="0,8,0,0"
                                            Orientation="Horizontal">
                                    <TextBlock Foreground="{StaticResource FgSecondaryBrush}"
                                               Text="{Binding VoiceAssistantConfidenceText}" />
                                    <TextBlock Foreground="{StaticResource FgLabelBrush}"
                                               Text=" / " />
                                    <TextBlock Foreground="{StaticResource FgSecondaryBrush}"
                                               Text="{Binding VoiceAssistantRiskLevelText}" />
                                </StackPanel>
                                <TextBlock Grid.Row="7" Margin="0,8,0,0" Foreground="{StaticResource FgLabelBrush}" Text="缺失数据" />
                                <TextBlock Grid.Row="7"
                                           Grid.Column="1"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource FgSecondaryBrush}"
                                           Text="{Binding VoiceAssistantMissingDataText}"
                                           TextWrapping="Wrap"
                                           ToolTip="{Binding VoiceAssistantMissingDataDetailText}" />
                            </Grid>
                        </Border>

                        <Border Grid.Row="1"
                                Grid.Column="1"
                                Margin="16,0,0,0"
                                Padding="14"
                                CornerRadius="8"
                                Background="{StaticResource BgCardBrush}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Foreground="{StaticResource FgLabelBrush}"
                                           Text="原因" />
                                <TextBlock Grid.Row="1"
                                           Margin="0,8,0,0"
                                           Foreground="{StaticResource FgSecondaryBrush}"
                                           Text="{Binding VoiceAssistantReasonText}"
                                           TextWrapping="Wrap" />
                                <ItemsControl Grid.Row="2"
                                              Margin="0,16,0,0"
                                              ItemsSource="{Binding RaceAssistantHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,8"
                                                    Padding="10"
                                                    CornerRadius="8"
                                                    Background="{StaticResource BgPanelBrush}">
                                                <StackPanel>
                                                    <TextBlock Foreground="{StaticResource FgLabelBrush}"
                                                               Text="{Binding Intent}" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{StaticResource FgPrimaryBrush}"
                                                               Text="{Binding Question}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Margin="0,4,0,0"
                                                               Foreground="{StaticResource FgSecondaryBrush}"
                                                               Text="{Binding Answer}"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3"
                    Grid.ColumnSpan="2"
                    Margin="0,16,0,0"
                    Padding="20"
                    CornerRadius="18"
                    Background="{StaticResource BgPanelBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FgPrimaryBrush}"
                               Text="AI / TTS 日志" />
                    <ItemsControl Grid.Row="1"
                                  Margin="0,16,0,0"
                                  ItemsSource="{Binding AiTtsLogs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,0,8"
                                        Padding="12"
                                        CornerRadius="12"
                                        Background="{StaticResource BgCardBrush}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="82" />
                                            <ColumnDefinition Width="70" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Foreground="{StaticResource FgLabelBrush}" Text="{Binding Timestamp}" />
                                        <TextBlock Grid.Column="1"
                                                   Foreground="{StaticResource FgSecondaryBrush}"
                                                   Text="{Binding Category}" />
                                        <TextBlock Grid.Column="2"
                                                   Foreground="{StaticResource FgPrimaryBrush}"
                                                   Text="{Binding Message}"
                                                   TextWrapping="Wrap" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</UserControl>
