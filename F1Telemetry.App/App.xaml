<Application x:Class="F1Telemetry.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/ThemeColors.xaml" />
                <ResourceDictionary Source="Styles/Spacing.xaml" />
                <ResourceDictionary Source="Styles/SharedStyles.xaml" />
                <ResourceDictionary Source="Styles/ShellStyles.xaml" />
                <ResourceDictionary Source="Styles/ScrollBarStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
